---
import '../styles/global.css';
import { getEntry } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '@fontsource/arimo/400.css';
import '@fontsource/arimo/700.css';
import '@fontsource/arimo/400-italic.css';
import '@fontsource/arimo/700-italic.css';
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';

interface Props {
	title?: string;
	description?: string;
	hideNav?: boolean;
}

const settingsEntry = await getEntry('pages', 'settings');
const settings = settingsEntry?.data || {};

const { 
	title = settings.site_title, 
	description = settings.site_description,
	hideNav = false
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={`${base}favicon.png`} />
		<link rel="apple-touch-icon" href={`${base}favicon.png`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />

		<style is:inline>
			/* Prevent FOUC */
			[data-astro-transition-scope] { visibility: hidden; }
			html.astro-ready [data-astro-transition-scope] { visibility: visible; }
		</style>
		
		<script is:inline define:vars={{ base }}>
			// Basic Gatekeeper script
			const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
			const isSplashPage = window.location.pathname === base || window.location.pathname === base.slice(0, -1) || window.location.pathname === '/';
			const isAdminPage = window.location.pathname.includes('/admin');

			if (!isLocalhost && !isSplashPage && !isAdminPage) {
				const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
				if (!user) {
					window.location.href = base;
				}
			}
		</script>
		<script is:inline>
			document.documentElement.classList.add('astro-ready');
			document.addEventListener('astro:after-swap', () => document.documentElement.classList.add('astro-ready'));
		</script>
	</head>
	<body class="bg-olive text-white/90 font-sans selection:bg-sage/30">
		{!hideNav && <Header transition:persist />}
		<slot />
		{!hideNav && <Footer />}
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Arimo', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
		--font-serif: 'Instrument Serif', Georgia, Cambria, "Times New Roman", Times, serif;
	}
	html {
		font-family: var(--font-sans);
		scroll-behavior: smooth;
	}
	h1, h2, h3, h4, h5, h6, .font-serif {
		font-family: var(--font-serif);
	}
</style>
