---
import '../styles/global.css';
import settings from '../content/settings.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	hideNav?: boolean;
}

const { 
	title = settings.site_title, 
	description = settings.site_description,
	hideNav = false
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={`${base}favicon.png`} />
		<link rel="apple-touch-icon" href={`${base}favicon.png`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Arimo:ital,wght@0,400..700;1,400..700&family=Instrument+Serif:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
		
		<script is:inline define:vars={{ base }}>
			// Basic Gatekeeper script
			const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
			const isSplashPage = window.location.pathname === base || window.location.pathname === base.slice(0, -1) || window.location.pathname === '/';
			const isAdminPage = window.location.pathname.includes('/admin');

			if (!isLocalhost && !isSplashPage && !isAdminPage) {
				const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
				if (!user) {
					window.location.href = base;
				}
			}
		</script>
	</head>
	<body class="bg-[#294b27] text-white/90 font-sans selection:bg-[#B2B29F]/30">
		{!hideNav && <Header />}
		<slot />
		{!hideNav && <Footer />}
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Arimo', sans-serif;
		--font-serif: 'Instrument Serif', serif;
	}
	html {
		font-family: var(--font-sans);
		scroll-behavior: smooth;
	}
	h1, h2, h3, h4, h5, h6, .font-serif {
		font-family: var(--font-serif);
	}
</style>
