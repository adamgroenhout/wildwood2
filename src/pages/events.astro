---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

import Button from '../components/Button.astro';

const eventsEntry = await getEntry('pages', 'events');
const { title, seo_title, subtitle, content, sections } = eventsEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="display-serif m-0 text-balance">{title}</h1>
				{subtitle && <p class="subtitle-serif m-0 mt-8 opacity-80 text-balance mx-auto max-w-2xl text-center">{subtitle}</p>}
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="space-y-24">
					{content?.map((p: string) => <div class="prose body-lg max-w-none opacity-90" set:html={marked.parse(p)} />)}

					{sections?.map((section: any, index: number) => (
						<div class={`space-y-12 ${index !== 0 ? 'pt-16 border-t border-current/10' : ''}`}>
							<div class="max-w-3xl mx-auto space-y-6">
								<h2 class="h1-serif italic text-center">{section.title}</h2>
								{section.text && <div class="body-lg opacity-90 prose max-w-none" set:html={marked.parse(section.text)} />}
							</div>
							
							{/* Highlight Box Logic (e.g. Book Club) */}
							{section.highlight && (
								<div class="bg-current/5 border border-current/10 p-8 md:p-12 rounded-brand shadow-sm max-w-3xl mx-auto space-y-8">
									<h3 class="h2-serif text-center">{section.highlight.title}</h3>
									<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
										{section.highlight.details?.map((detail: any) => (
											<div class="border-b border-current/5 pb-2">
												<p class="eyebrow opacity-60 mb-1">{detail.label}</p>
												<p class="text-sm font-medium">{detail.text}</p>
											</div>
										))}
									</div>
									{section.highlight.cta_text && (
										<div class="pt-4 text-center">
											<Button href={section.highlight.cta_url || '#'} theme="terracotta">
												{section.highlight.cta_text}
											</Button>
										</div>
									)}
								</div>
							)}

							{/* Items List Logic (e.g. Community Events, Clinicians) */}
							{section.items && (
								<div class="grid grid-cols-1 gap-12">
									{section.items.map((item: any) => (
										<div class="bg-current/5 border border-current/10 p-8 md:p-12 rounded-brand shadow-sm space-y-8 max-w-3xl mx-auto w-full">
											<div class="text-center space-y-2">
												<h3 class="h2-serif">{item.name}</h3>
												<div class="flex flex-wrap justify-center gap-4 eyebrow opacity-60 text-xs">
													{item.location && <span>{item.location}</span>}
													{item.cost && <span>• {item.cost}</span>}
												</div>
											</div>

											{item.text && <div class="prose body-lg max-w-none opacity-90" set:html={marked.parse(item.text)} />}
											
											{item.footer && (
												<div class="pt-6 border-t border-current/10">
													<p class="text-sm italic opacity-70 text-center">{item.footer}</p>
												</div>
											)}

											{item.cta_text && (
												<div class="pt-4 text-center">
													<Button href={item.cta_url || '#'} theme="terracotta">
														{item.cta_text}
													</Button>
												</div>
											)}
										</div>
									))}
								</div>
							)}
						</div>
					))}
				</div>
			</div>
		</Section>
	</main>
</Layout>
