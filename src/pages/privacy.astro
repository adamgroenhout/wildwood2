---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { marked } from 'marked';

const privacyEntry = await getEntry('pages', 'privacy');
const { title, seo_title, content } = privacyEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif">Privacy Policy</h1>
			</div>
		</Section>

    <Section theme="alternate">
      <div class="max-w-4xl mx-auto">
        <div class="prose body-lg max-w-none opacity-90" set:html={marked.parse(content || '')} />
      </div>
    </Section>
	</main>
</Layout>
