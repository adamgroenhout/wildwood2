---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

const hitEntry = await getEntry('pages', 'holding-it-together');
const { 
  title, 
  subtitle, 
  seo_title,
  hero_section,
  who_for_section,
  program_details,
  footer_cta
} = hitEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif m-0">{title}</h1>
				{subtitle && <p class="subtitle-serif m-0 mt-[var(--spacing-hero-title-gap)] md:mt-[var(--spacing-hero-title-gap-md)] opacity-80 text-center text-balance mx-auto max-w-2xl">{subtitle}</p>}
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
        {/* Intro Section */}
				<div class="bg-current/5 p-10 md:p-16 border border-current/10 rounded-brand text-center shadow-xl mb-24">
					<h2 class="h1-serif italic mb-8">{hero_section?.title}</h2>
					<div class="max-w-2xl mx-auto space-y-8 opacity-90 body-lg prose">
            <div set:html={marked.parse(hero_section?.text1 || '')} />
            <div set:html={marked.parse(hero_section?.text2 || '')} />
            <div set:html={marked.parse(hero_section?.text3 || '')} />
          </div>
				</div>

        {/* Who For Section */}
        <div class="space-y-16 py-16">
          <h2 class="h1-serif text-center italic">{who_for_section?.title}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {who_for_section?.points?.map((point: string) => (
              <div class="bg-current/5 border border-current/10 p-8 rounded-brand shadow-sm">
                <p class="body-lg opacity-90">{point}</p>
              </div>
            ))}
          </div>
          <p class="text-center subtitle-serif italic opacity-70">{who_for_section?.footer_italic}</p>
        </div>
      </div>
    </Section>

    <Section theme="alternate">
      <div class="max-w-4xl mx-auto">
        {/* Program Details */}
        <div class="space-y-16">
          <h2 class="h1-serif text-center italic">{program_details?.title}</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-current/5 p-8 border border-current/10 rounded-brand text-center shadow-sm">
              <p class="eyebrow mb-3 opacity-60">Duration</p>
              <p class="h3-serif">{program_details?.duration}</p>
            </div>
            <div class="bg-current/5 p-8 border border-current/10 rounded-brand text-center shadow-sm">
              <p class="eyebrow mb-3 opacity-60">Format</p>
              <p class="h3-serif">{program_details?.format}</p>
            </div>
            <div class="bg-current/5 p-8 border border-current/10 rounded-brand text-center shadow-sm">
              <p class="eyebrow mb-3 opacity-60">Location</p>
              <p class="h3-serif">{program_details?.location}</p>
            </div>
          </div>

          <div class="bg-current/5 p-10 md:p-16 border border-current/10 rounded-brand max-w-3xl mx-auto shadow-lg">
            <h3 class="eyebrow mb-10 text-center opacity-70">{program_details?.weekly_focus?.title}</h3>
            <div class="space-y-6 text-left max-w-md mx-auto">
              {program_details?.weekly_focus?.weeks?.map((week: string, index: number) => (
                <div class="flex gap-8 items-baseline border-b border-current/10 pb-4 last:border-0">
                  <span class="h3-serif italic opacity-70 shrink-0">Week {index + 1}</span>
                  <span class="body-lg opacity-90">{week}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </Section>

    <Section theme="charcoal">
      <div class="max-w-4xl mx-auto text-center space-y-12">
        {/* Footer CTA */}
        <h2 class="display-serif italic text-center text-balance">{footer_cta?.title}</h2>
        <div class="max-w-2xl mx-auto opacity-90 body-lg prose">
          <p>{footer_cta?.text}</p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 pt-8">
          <Button href={footer_cta?.primary_button?.url || '#'} theme="terracotta">
            {footer_cta?.primary_button?.text}
          </Button>
          <Button href={footer_cta?.secondary_button?.url || '#'} theme="white">
            {footer_cta?.secondary_button?.text}
          </Button>
        </div>
			</div>
		</Section>
	</main>
</Layout>
