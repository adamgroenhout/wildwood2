---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const pageEntries = await getCollection('site_pages');
  
  return pageEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, subtitle, seo_title, blocks } = entry.data;
---

<Layout title={seo_title || title}>
	<main>
		{/* Check if the user already added a hero block. If not, give them a standard page header using the title. */}
		{!blocks?.some((b: any) => b.type === 'hero') && (
			<Section theme="alternate" padding="hero" class="text-center">
				<div class="max-w-4xl mx-auto">
					<h1 class="display-serif m-0 whitespace-pre-wrap text-center text-pretty">
						{title.split('\n').map((line: string, i: number) => (
							<Fragment key={i}>
								{i > 0 && <br />}
								{line}
							</Fragment>
						))}
					</h1>
					{subtitle && (
						<p class="subtitle-serif m-0 text-center mt-[var(--spacing-hero-title-gap)] md:mt-[var(--spacing-hero-title-gap-md)] whitespace-pre-wrap opacity-80 text-pretty">
							{subtitle.split('\n').map((line: string, i: number) => (
								<Fragment key={i}>
									{i > 0 && <br />}
									{line}
								</Fragment>
							))}
						</p>
					)}
				</div>
			</Section>
		)}
		{blocks && <BlockRenderer blocks={blocks} />}
	</main>
</Layout>
