---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, subtitle, seo_title, sections, cta_text, cta_url } = entry.data;
---

<Layout title={seo_title}>
	<main>
		<section class="bg-alternate pt-32 pb-10 px-4">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif mb-10 text-center text-balance">{title}</h1>
				{subtitle && <p class="subtitle-serif text-center mb-12 text-balance">{subtitle}</p>}
			</div>
		</section>
		
		{/* Split sections into two groups to force a background color change halfway through */}
		{(() => {
			const midPoint = Math.ceil(sections.length / 2);
			const firstHalf = sections.slice(0, midPoint);
			const secondHalf = sections.slice(midPoint);
			
			const renderSection = (section: any) => {
				if (section.type === 'text') {
					return (
						<div class={`mb-12 ${section.style === 'highlighted' ? "bg-white/5 p-8 border border-white/10" : ""}`}>
							{section.title && <h2 class="h1-serif mb-6 text-balance">{section.title}</h2>}
							<div class="space-y-4" set:html={marked(section.body)} />
						</div>
					);
				} else if (section.type === 'list') {
					return (
						<div class="mb-12">
							{section.title && <h2 class="h1-serif mb-6 text-center italic text-balance">{section.title}</h2>}
							<ul class="grid grid-cols-1 md:grid-cols-2 gap-4 list-none pl-0">
								{section.items.map((item: string) => (
									<li class="border-l-4 border-terracotta/40 pl-4 py-2 hover:border-terracotta transition-colors">{item}</li>
								))}
							</ul>
						</div>
					);
				}
				return null;
			};

			return (
				<>
					<section class="bg-alternate py-20 px-4">
						<div class="max-w-4xl mx-auto">
							<div class="prose prose-invert body-lg max-w-none  space-y-8">
								{firstHalf.map(renderSection)}
							</div>
						</div>
					</section>

					<section class="bg-alternate py-20 px-4">
						<div class="max-w-4xl mx-auto">
							<div class="prose prose-invert body-lg max-w-none  space-y-8">
								{secondHalf.map(renderSection)}
								
								<div class="mt-16 text-center">
									<a href={cta_url} class="bg-terracotta inline-block px-6 md:px-10 py-4 eyebrow hover:bg-terracotta-dark transition-all text-center">
										{cta_text}
									</a>
								</div>
							</div>
						</div>
					</section>
				</>
			);
		})()}
	</main>
</Layout>
