---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BackToTop from '../components/BackToTop.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

const faqsEntry = await getEntry('pages', 'faqs');
const { title, faqs, footer_cta_text, footer_cta_button_text, footer_cta_url, meta_description } = faqsEntry?.data || {};

// Strip markdown for meta tag
const cleanDescription = meta_description?.replace(/[#*`]/g, '') || "Frequently Asked Questions about Wildwood Psychotherapy.";

// Generate FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs?.filter((f: any) => f.question && f.answer).map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer?.replace(/[#*`]/g, '') // Schema should be plain text
    }
  }))
};
---

<Layout title="FAQs | Wildwood Psychotherapy" description={cleanDescription}>
	<!-- Inject FAQ Schema -->
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

	<main>
		<section class="bg-alternate pt-48 pb-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif mb-10 text-center ">{title}</h1>
			</div>
		</section>

		{(() => {
			const midPoint = Math.ceil((faqs?.length || 0) / 2);
			const firstHalf = faqs?.slice(0, midPoint) || [];
			const secondHalf = faqs?.slice(midPoint) || [];

			const renderFaqs = (faqList: any[]) => (
				<div class="prose prose-invert body-lg max-w-none  space-y-8">
					<div class="space-y-8">
						{faqList.map(faq => (
							<div class="bg-terracotta/5 p-8 border border-white/5 rounded-lg">
								<h3 class="h2-serif mb-4 ">{faq.question}</h3>
								
								{faq.answer && (
									<div class="prose prose-invert text-white/80 max-w-none" set:html={marked.parse(faq.answer || '')} />
								)}

								{faq.rates && (
									<ul class="list-none pl-0 space-y-2 mt-4">
										{faq.rates.map((rate: any) => (
											<li class="flex justify-between border-b border-white/10 pb-2">
												<span set:html={rate.service} /> 
												<span class={`${rate.is_italic ? ' italic' : ' font-bold'}`}>{rate.price}</span>
											</li>
										))}
									</ul>
								)}
							</div>
						))}
					</div>
				</div>
			);

			return (
				<>
					<section class="bg-alternate py-20 px-4">
						<div class="max-w-4xl mx-auto">
							{renderFaqs(firstHalf)}
						</div>
					</section>

					<section class="bg-alternate py-20 px-4">
						<div class="max-w-4xl mx-auto text-center">
							{renderFaqs(secondHalf)}
							
							<div class="mt-20 pt-20 border-t border-white/10 text-center space-y-8">
								<h2 class="h1-serif italic text-balance">{footer_cta_text}</h2>
								<div class="pt-4">
									<a href={formatUrl(footer_cta_url)} class="bg-terracotta inline-block px-6 md:px-10 py-4 eyebrow hover:bg-terracotta-dark transition-all text-center">
										{footer_cta_button_text}
									</a>
								</div>
							</div>

						</div>
					</section>
				</>
			);
		})()}
		<BackToTop />
	</main>
</Layout>
