---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Accordion from '../components/Accordion.astro';
import { formatUrl } from '../utils/paths';

import Button from '../components/Button.astro';
const faqsEntry = await getEntry('pages', 'faqs');
const { 
  title, 
  seo_title,
  faqs, 
  footer_cta_text,
  footer_cta_button_text,
  footer_cta_url,
  meta_description
} = faqsEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif text-balance">{title}</h1>
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="space-y-16">
					{faqs?.map((faq: any) => (
            <div class="space-y-8">
              {faq.rates ? (
                <div class="space-y-8">
                  <h2 class="h1-serif text-center mb-12 text-balance">{faq.question}</h2>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 opacity-90">
                    {faq.rates?.map((item: any) => (
                      <div class="bg-current/5 p-8 border border-current/10 rounded-brand flex flex-col justify-between">
                        <h3 class={`eyebrow mb-4 opacity-70 ${item.is_italic ? 'italic' : ''}`} set:html={item.service}></h3>
                        <div class="flex justify-between items-baseline gap-4 border-b border-current/5 pb-2">
                          <span class="font-bold text-xl">{item.price}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ) : (
                <Accordion items={[{ title: faq.question, content: faq.answer }]} />
              )}
            </div>
          ))}
				</div>
			</div>
		</Section>

		<Section theme="charcoal">
			<div class="max-w-4xl mx-auto text-center space-y-10">
				<h2 class="display-serif italic text-balance">{footer_cta_text}</h2>
				<div class="pt-8">
					<Button href={footer_cta_url || '#'} theme="terracotta">
						{footer_cta_button_text}
					</Button>
				</div>
			</div>
		</Section>
	</main>
</Layout>
