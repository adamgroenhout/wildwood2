---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

const groupEntry = await getEntry('pages', 'group-therapy');
const { 
  title, 
  seo_title, 
  subtitle, 
  intro,
  benefits_section,
  featured_group,
  is_right_section,
  cta_text, 
  cta_url 
} = groupEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif text-balance">{title}</h1>
				{subtitle && <p class="subtitle-serif opacity-80 text-balance mx-auto max-w-2xl text-center mt-[var(--spacing-hero-title-gap)] md:mt-[var(--spacing-hero-title-gap-md)]">{subtitle}</p>}
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
        {/* Intro */}
				<div class="text-center space-y-10 mb-24">
					<h2 class="h1-serif text-balance">{intro?.title}</h2>
					<div class="prose body-lg max-w-2xl mx-auto opacity-90 text-left">
            <p>{intro?.text1}</p>
            <p class="subtitle-serif italic opacity-90 mt-8 text-center">"{intro?.quote}"</p>
          </div>
				</div>

        {/* Benefits Grid */}
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-16">
					{benefits_section?.benefits?.map((item: any) => (
						<div class="bg-current/5 p-8 border border-current/10 rounded-brand space-y-4 shadow-sm">
							<h3 class="h3-serif italic">{item.title}</h3>
							<p class="text-sm opacity-90">{item.text}</p>
						</div>
					))}
				</div>

        {/* Featured Group Callout */}
				<div class="mt-24 pt-24 text-center space-y-12">
					<div class="bg-current/5 p-12 rounded-brand border border-current/10 mb-20 shadow-xl">
						<h2 class="display-serif italic mb-2 text-balance">{featured_group?.title}</h2>
            <p class="eyebrow mb-6 opacity-70">{featured_group?.subtitle}</p>
            <div class="prose body-lg max-w-2xl mx-auto mb-8 opacity-90 text-left" set:html={marked.parse(featured_group?.text || '')} />
						<div class="pt-4">
							<Button href={featured_group?.cta_url || '#'} theme="outline">
								{featured_group?.cta_text}
							</Button>
						</div>
					</div>

          {/* Is it right? */}
					<div class="max-w-3xl mx-auto space-y-8 text-left">
						<h3 class="h2-serif italic text-center">{is_right_section?.title}</h3>
						<p class="body-lg opacity-90">{is_right_section?.text}</p>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 list-none pl-0">
              {is_right_section?.points?.map((point: string) => (
                <li class="border-l-4 border-terracotta/40 pl-4 py-2">{point}</li>
              ))}
            </ul>
					</div>

          <div class="pt-16">
            <Button href={cta_url || '#'} theme="terracotta">
              {cta_text}
            </Button>
          </div>
				</div>
			</div>
		</Section>
	</main>
</Layout>
