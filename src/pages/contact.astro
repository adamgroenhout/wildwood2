---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Carousel from '../components/Carousel.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

const contactEntry = await getEntry('pages', 'contact');
const { title, seo_title, intro_title, intro_text, cta_text, cta_url, location, parking, arrival, studio_title, studio_images } = contactEntry?.data || {};

const carouselImages = studio_images?.map((item: any) => formatUrl(item.image)) || [];
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif text-balance">{title}</h1>
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="body-lg max-w-none opacity-90">
					<div>
						<h2 class="h1-serif mb-6 italic text-center">{intro_title}</h2>
						<div class="prose mx-auto" set:html={marked.parse(intro_text || '')} />
						
						<div class="mt-8 text-center">
							<Button href={cta_url} theme="terracotta">
								{cta_text}
							</Button>
						</div>
					</div>
				</div>
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="body-lg max-w-none space-y-12">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16 border-t border-current/10 pt-12">
						<div class="bg-current/5 p-8 border border-current/10 rounded-brand">
							<h3 class="h2-serif mb-4 ">{location?.title || 'Location'}</h3>
							<p>{location?.name}</p>
							<p>{location?.address_line1}</p>
							<p>{location?.address_line2}</p>
							<p class="mt-4"><strong class="">Phone:</strong> {location?.phone}</p>
							<p><strong class="">Email:</strong> <a href={`mailto:${location?.email}`} class="hover:text-terracotta transition-colors">{location?.email}</a></p>
						</div>

						<div class="bg-current/5 p-8 border border-current/10 rounded-brand">
							<h3 class="h2-serif mb-4 ">{parking?.title || 'Parking'}</h3>
							{parking?.options?.map((option: any) => (
								<p><strong class="">{option.label}:</strong> {option.text}</p>
							))}
						</div>
					</div>

					<div class="bg-current/5 p-8 rounded-brand border border-current/10">
						<h3 class="h2-serif mb-4 ">{arrival?.title || 'Upon Arrival'}</h3>
						<div class="prose max-w-none" set:html={marked.parse(arrival?.text || '')} />
					</div>

					{carouselImages.length > 0 && (
						<div class="mt-12 text-center">
							<h3 class="h2-serif mb-6 italic">{studio_title}</h3>
							<Carousel images={carouselImages} />
						</div>
					)}
				</div>
			</div>
		</Section>
	</main>
</Layout>
