---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { getEntry } from 'astro:content';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

const gfeEntry = await getEntry('pages', 'good-faith-estimate');
const { title, seo_title, subtitle, content, highlight_box, footer_text, footer_url, keep_in_mind } = gfeEntry?.data || {};

// Handle the footer link more robustly
const linkPlaceholder = "www.cms.gov/nosurprises";
const footerParts = (footer_text || "").split(linkPlaceholder);
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif">{title}</h1>
				{subtitle && <p class="subtitle-serif mt-8 opacity-80">{subtitle}</p>}
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="prose body-lg max-w-none space-y-8 opacity-90">
					{content.map((p: string) => <div set:html={marked.parse(p)} />)}

					<div class="bg-current/5 p-8 border border-current/10 rounded-brand space-y-6">
						{highlight_box.map((p: string) => <div class="opacity-90" set:html={marked.parse(p)} />)}
					</div>

					<div class="pt-8 opacity-80 italic text-center">
						<p>
							{footerParts[0]}
							<a href={footer_url} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">
								{linkPlaceholder}
							</a>
							{footerParts[1]}
						</p>
					</div>

					<div class="mt-12 pt-12 border-t border-current/10">
						<h3 class="h2-serif mb-6 italic text-center">{keep_in_mind.title}</h3>
						<div class="opacity-90 space-y-4" set:html={marked.parse(keep_in_mind.text)} />
					</div>
				</div>
			</div>
		</Section>
	</main>
</Layout>
