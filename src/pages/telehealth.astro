---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';

const telehealthEntry = await getEntry('pages', 'telehealth');
const { 
  title, 
  seo_title,
  subtitle, 
  why_telehealth, 
  what_to_expect, 
  bottom_text, 
  cta_text, 
  cta_url 
} = telehealthEntry?.data || {};
---

<Layout title={seo_title}>	<main>
		<Section theme="alternate" padding="hero" class="text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="display-serif text-balance">{title}</h1>
				{subtitle && <p class="subtitle-serif opacity-80 text-balance mx-auto max-w-2xl text-center mt-[var(--spacing-hero-title-gap)] md:mt-[var(--spacing-hero-title-gap-md)]">{subtitle}</p>}
			</div>
		</Section>

		<Section theme="alternate">
			<div class="max-w-4xl mx-auto">
				<div class="space-y-20">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start border-b border-current/10 pb-20">
            <div class="space-y-6">
              <h2 class="h2-serif italic">{why_telehealth?.title}</h2>
              <div class="space-y-4">
                {why_telehealth?.items?.map((item: any) => (
                  <p><strong class="text-olive">{item.label}:</strong> {item.text}</p>
                ))}
              </div>
            </div>
            <div class="space-y-6">
              <h2 class="h2-serif italic">{what_to_expect?.title}</h2>
              <div class="space-y-4">
                {what_to_expect?.steps?.map((item: any) => (
                  <p><strong class="text-olive">{item.label}:</strong> {item.text}</p>
                ))}
              </div>
            </div>
					</div>

					<div class="space-y-12">
						<div class="prose body-lg max-w-2xl mx-auto italic opacity-90" set:html={marked.parse(bottom_text || '')} />
						
						<div class="pt-8 text-center">
						  <Button href={cta_url || '#'} theme="terracotta">
						    {cta_text}
						  </Button>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</main>
</Layout>
