---
import Layout from '../layouts/Layout.astro';
import BackToTop from '../components/BackToTop.astro';
import homepageData from '../content/homepage.json';
import { marked } from 'marked';

const { 
	hero_subtitle, 
	hero_title, 
	hero_image, 
	cta_text, 
	cta_url, 
	specialties_header,
	specialties, 
	intro_title, 
	intro_text, 
	feature_image, 
	feature_title, 
	feature_text, 
	feature_link_text, 
	feature_link_url,
	wounds_header,
	resources_title,
	resources_text,
	resources_items,
	adaptations_text,
	trauma_therapist_text,
	root_title,
	root_content,
	is_this_you_title,
	is_this_you_items,
	how_to_start_title,
	how_to_start_items,
	callout_title,
	callout_text,
	callout_image,
	final_cta_tagline,
	final_cta_title,
	final_cta_button_text,
	kaylie_title,
	kaylie_subtitle,
	kaylie_bio,
	kaylie_link_text,
	kaylie_link_url,
	hero_alt,
	feature_alt,
	kaylie_alt,
	callout_alt,
	final_cta_alt,
	seo_title
} = homepageData;
const base = import.meta.env.BASE_URL;

// Helper to format URLs correctly with base path
const formatUrl = (url: string) => {
  if (!url) return '#';
  if (url === '#' || url.startsWith('http')) return url;
  if (url.startsWith(base)) return url;
  return `${base}${url.startsWith('/') ? url.slice(1) : url}`;
};
---

<Layout title={seo_title}>
	
	<main>
		{/* Hero Section */}
		<section class="bg-alternate relative h-screen flex flex-col justify-center items-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<img 
					src={hero_image.startsWith('http') ? hero_image : (hero_image.startsWith(base) ? hero_image : `${base}${hero_image.startsWith('/') ? hero_image.slice(1) : hero_image}`)}
					alt={hero_alt} 
					class="w-full h-full object-cover filter brightness-[0.4]"
				/>
			</div>
			
			<div class="relative z-10 text-center text-white px-4 max-w-4xl">
				<p class="text-[10px] md:text-xs uppercase tracking-[0.3em] font-sans font-medium mb-8 opacity-0 animate-[fadeInUp_0.8s_ease-out_forwards]">
					{hero_subtitle}
				</p>
				<h1 class="text-6xl md:text-8xl font-serif mb-10 leading-tight text-balance opacity-0 animate-[fadeInUp_0.8s_ease-out_0.2s_forwards]">
					{hero_title.split('*').map((part, i) => i % 2 === 1 ? <em class="italic">{part}</em> : part)}
				</h1>
				
				<div class="flex flex-col items-center gap-10 mt-10 opacity-0 animate-[fadeInUp_0.8s_ease-out_0.4s_forwards]">
					<a href={cta_url} class="bg-[#B17048] text-[#F9F7F0] inline-block px-6 md:px-10 py-4 text-sm font-medium hover:bg-[#965d3a] transition-all uppercase tracking-widest text-center hover:shadow-2xl active:scale-[0.98]">
						{cta_text}
					</a>
					
					<div class="flex flex-wrap justify-center gap-4 mt-4">
						{specialties.map(spec => (
							<a href={formatUrl(spec.url)} class="border border-white/40 px-6 py-2 text-sm hover:border-white transition-all duration-300 hover:bg-white/5 active:scale-95">
								{spec.name}
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		{/* Section 2: Values/Intro */}
		<section class="bg-alternate py-32 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-serif mb-10 text-balance">{intro_title}</h2>
				<div class="text-lg leading-relaxed max-w-2xl mx-auto opacity-90 prose prose-invert">
					{intro_text.split('\n\n').map(p => <p class="mb-6 last:mb-0">{p}</p>)}
				</div>
			</div>
		</section>

		{/* Section 3: Feature Section */}
		<section class="bg-alternate py-20 overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center gap-16">
				<div class="w-full md:w-1/2 group">
					<img
						src={feature_image.startsWith('http') ? feature_image : (feature_image.startsWith(base) ? feature_image : `${base}${feature_image.startsWith('/') ? feature_image.slice(1) : feature_image}`)}
						alt={feature_alt}
						class="w-full h-[400px] md:h-[600px] object-cover grayscale group-hover:grayscale-0 transition-all duration-1000"
					/>
				</div>
				<div class="w-full md:w-1/2 space-y-6">
					<h3 class="text-4xl font-serif text-balance">{feature_title}</h3>
					<div class="leading-relaxed opacity-90 prose prose-invert" set:html={marked.parse(feature_text || '')} />
					<div class="flex justify-end pt-4">
						<a href={formatUrl(feature_link_url)} class="inline-flex items-center gap-2 text-sm uppercase tracking-widest border-b border-white/20 pb-1 transition-all duration-300 hover:border-[#B17048] hover:text-[#B17048] group">
							<span>{feature_link_text}</span>
							<svg class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</div>
				</div>
			</div>
		</section>

		{/* Section 4: Expandable Content Section */}
		<section class="bg-[#414244] text-[#f9f7f0] py-32 px-4">
			<div class="max-w-6xl mx-auto space-y-16">
				<h2 class="text-4xl md:text-7xl font-serif text-center italic opacity-90">{wounds_header}</h2>
				
				<div class="grid md:grid-cols-2 gap-20 items-start">
					<div class="space-y-8 text-left pt-2">
						<h3 class="text-3xl md:text-5xl font-serif text-balance leading-tight">{resources_title}</h3>
						<div class="text-lg opacity-80 leading-relaxed prose prose-invert max-w-md" set:html={marked.parse(resources_text || '')} />
					</div>

					<div class="space-y-2">
						{resources_items.map((item) => (
							<details class="group border-b border-white/10 last:border-0 pb-6 pt-2">
								<summary class="flex justify-between items-center cursor-pointer list-none py-2 text-xl font-serif italic hover:text-[#B17048] transition-colors">
									<span>{item.title}</span>
									<span class="text-3xl transition-transform group-open:rotate-45 block leading-none">+</span>
								</summary>
								<div class="pt-4 pb-2 opacity-70 leading-relaxed text-base prose prose-invert" set:html={marked.parse(item.content || '')} />
							</details>
						))}
					</div>
				</div>

				<div class="mt-24 pt-20 border-t border-white/10 max-w-3xl mx-auto text-center space-y-8">
					<p class="text-2xl md:text-3xl font-serif italic leading-snug">
						{adaptations_text}
					</p>
					<p class="text-lg opacity-80 leading-relaxed uppercase tracking-widest text-sm">
						{trauma_therapist_text}
					</p>
				</div>
			</div>
		</section>

		{/* Section 4.5: Root Therapy Section */}
		<section class="bg-[#eeebdf] text-[#414244] py-32 px-4">
			<div class="max-w-4xl mx-auto text-center space-y-10">
				<h2 class="text-4xl md:text-6xl font-serif leading-tight">{root_title}</h2>
				<div class="max-w-3xl mx-auto text-lg leading-relaxed opacity-90 prose text-center">
					<div set:html={marked.parse(root_content || '')} />
				</div>

				<div class="mt-24 pt-20 border-t border-black/10 max-w-3xl mx-auto text-center space-y-12">
					<h3 class="text-3xl md:text-5xl font-serif italic">{is_this_you_title}</h3>
					
					<div class="space-y-10 text-lg leading-relaxed opacity-90 prose text-center">
						{is_this_you_items.map(item => (
							<div>
								<h4 class="text-xl uppercase tracking-widest font-bold mb-4">{item.title}</h4>
								{item.subtitle && <p class="italic mb-4">{item.subtitle}</p>}
								<div set:html={marked.parse(item.body || '')} />
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		{/* Section 5: Introduction Section */}
		<section class="bg-[#eeebdf] text-[#414244] py-32 px-4">
			<div class="max-w-5xl mx-auto">
				<div class="flex flex-col md:flex-row gap-12 items-center">
					<div class="w-full md:w-1/3">
						<img 
							src={`${base}images/kaylie-groenhout-headshot.jpg`} 
							alt={kaylie_alt} 
							class="w-full h-auto object-cover rounded-sm shadow-md"
						/>
					</div>
					<div class="w-full md:w-2/3 space-y-8">
						<div class="max-w-2xl">
							<h2 class="text-5xl md:text-7xl font-serif mb-4">{kaylie_title}</h2>
							<p class="text-xl md:text-2xl font-serif italic opacity-80">{kaylie_subtitle}</p>
						</div>
						
						<div class="space-y-6">
							<div class="text-lg leading-relaxed opacity-90 max-w-3xl prose" set:html={marked.parse(kaylie_bio || '')} />
							
							<div class="flex justify-end">
								<a href={formatUrl(kaylie_link_url)} class="inline-flex items-center gap-2 text-sm uppercase tracking-widest font-medium hover:text-[#B17048] transition-colors group">
									<span>{kaylie_link_text}</span>
									<svg class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
									</svg>
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* Section 6: Specialties Summary */}
		<section class="bg-alternate py-32 px-4 border-t border-black/5">
			<div class="max-w-4xl mx-auto text-center space-y-12">
				<h2 class="text-4xl md:text-6xl font-serif uppercase">{specialties_header}</h2>
				<div class="flex flex-col items-center gap-y-6 text-sm md:text-base font-medium tracking-[0.2em] uppercase opacity-80">
					{specialties.map((spec, index) => (
						<>
							<span>{spec.name}</span>
							{index < specialties.length - 1 && <div class="w-12 h-px bg-black/20"></div>}
						</>
					))}
				</div>
			</div>
		</section>

		{/* Section 7: How to Get Started */}
		<section class="bg-[#B17048] text-[#F9F7F0] py-32 px-4">
			<div class="max-w-4xl mx-auto text-center space-y-12">
				<h2 class="text-4xl md:text-6xl font-serif italic lowercase tracking-tight">{how_to_start_title}</h2>
				<div class="w-3/4 h-px bg-white/30 mx-auto"></div>
				
				<div class="grid md:grid-cols-3 gap-20 mt-20">
					{how_to_start_items.map(item => (
						<div class="space-y-6">
							<span class="text-4xl font-serif opacity-40">{item.number}</span>
							<h3 class="text-xl uppercase tracking-widest font-bold">{item.title}</h3>
							<div class="text-sm opacity-80 leading-relaxed" set:html={marked.parse(item.text || '')} />
						</div>
					))}
				</div>
			</div>
		</section>

		{/* Section 8: Callout Section */}
		<section class="bg-[#EEEBDF] text-[#414244] py-32 px-4">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
				<div class="w-full md:w-1/2 text-left space-y-8">
					<h2 class="text-3xl md:text-5xl font-sans font-bold tracking-[0.2em] uppercase leading-tight text-balance">
						{callout_title}
					</h2>
					<div class="space-y-6 text-lg leading-relaxed opacity-90 prose" set:html={marked.parse(callout_text || '')} />
				</div>
				<div class="w-full md:w-1/2">
					<img 
						src={callout_image.startsWith('http') ? callout_image : (callout_image.startsWith(base) ? callout_image : `${base}${callout_image.startsWith('/') ? callout_image.slice(1) : callout_image}`)}
						alt={callout_alt}
						class="w-full aspect-[4/3] object-cover rounded-sm shadow-xl"
					/>
				</div>
			</div>
		</section>

		{/* Section 9: Final CTA Section */}
		<section class="flex flex-col md:flex-row min-h-[600px]">
			<div class="w-full md:w-1/2 bg-alternate flex items-center justify-center p-0">
				<img 
					src={hero_image.startsWith('http') ? hero_image : (hero_image.startsWith(base) ? hero_image : `${base}${hero_image.startsWith('/') ? hero_image.slice(1) : hero_image}`)}
					alt={final_cta_alt}
					class="w-full h-full object-cover grayscale opacity-60"
				/>
			</div>
			<div class="w-full md:w-1/2 bg-[#294b27] text-white flex flex-col items-center justify-center p-12 text-center space-y-10">
				<div class="space-y-6">
					<h2 class="text-lg md:text-xl uppercase tracking-[0.2em] font-sans opacity-80">{final_cta_tagline}</h2>
					<p class="text-4xl md:text-6xl font-serif italic leading-tight">{final_cta_title}</p>
				</div>
				
				<div class="pt-6">
					<a href={cta_url} class="inline-block border border-white px-10 py-4 text-sm font-medium hover:bg-white hover:text-[#294b27] transition-all uppercase tracking-widest text-center shadow-lg active:scale-95">
						{final_cta_button_text}
					</a>
				</div>
			</div>
		</section>

		<BackToTop />
	</main>
</Layout>
