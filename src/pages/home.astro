---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BackToTop from '../components/BackToTop.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Accordion from '../components/Accordion.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';
import { Image } from 'astro:assets';

const homepageEntry = await getEntry('pages', 'homepage');
const { 
	hero_subtitle, 
	hero_title, 
	hero_image, 
	cta_text, 
	cta_url, 
	specialties, 
	intro_title, 
	intro_text, 
	feature_image, 
	feature_title, 
	feature_text, 
	feature_link_text, 
	feature_link_url,
	wounds_header,
	resources_title,
	resources_text,
	resources_items,
	adaptations_text,
	trauma_therapist_text,
	root_title,
	root_content,
	is_this_you_title,
	is_this_you_items,
	how_to_start_title,
	how_to_start_items,
	callout_title,
	callout_text,
	callout_image,
	final_cta_tagline,
	final_cta_title,
	final_cta_button_text,
	kaylie_title,
	kaylie_subtitle,
	kaylie_bio,
	kaylie_link_text,
	kaylie_link_url,
	hero_alt,
	feature_alt,
	kaylie_alt,
	callout_alt,
	final_cta_alt,
	seo_title
} = homepageEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		{/* Hero Section */}
		<Section theme="alternate" padding="hero" class="relative h-screen flex flex-col justify-center items-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				{hero_image && (
					<Image 
						src={formatUrl(hero_image)}
						alt={hero_alt || ''} 
						width={1920}
						height={1080}
						class="w-full h-full object-cover filter brightness-[0.4]"
						loading="eager"
					/>
				)}
			</div>
			
			<div class="relative z-10 text-center text-white px-4 max-w-4xl">
				<p class="eyebrow text-center mb-8 animate-[fadeInUp_0.8s_ease-out_forwards] text-white/90">
					{hero_subtitle}
				</p>
				<h1 class="display-serif mb-10 text-balance animate-[fadeInUp_0.8s_ease-out_0.2s_forwards]">
					{hero_title?.split('*').map((part: string, i: number) => i % 2 === 1 ? <em class="italic">{part}</em> : part)}
				</h1>
				
				<div class="flex flex-col items-center gap-10 mt-10 animate-[fadeInUp_0.8s_ease-out_0.4s_forwards]">
					<Button href={cta_url || '#'} theme="terracotta">
						{cta_text}
					</Button>
					
					<div class="flex flex-wrap justify-center gap-4 mt-4">
						{specialties?.map((spec: any) => (
							<a href={formatUrl(spec.url)} class="border border-white/40 px-6 py-2 text-sm hover:border-white transition-all duration-300 hover:bg-white/5 active:scale-95">
								{spec.name}
							</a>
						))}
					</div>
				</div>
			</div>
		</Section>

		{/* Section 2: Values/Intro */}
		<Section theme="alternate">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="h1-serif mb-10 text-balance">{intro_title}</h2>
				<div class="body-lg max-w-2xl mx-auto opacity-90 prose prose-invert text-left">
					{intro_text?.split('\n\n').map((p: string) => <p class="mb-6 last:mb-0 text-left">{p}</p>)}
				</div>
			</div>
		</Section>

		{/* Section 3: Feature Section */}
		<Section theme="alternate" padding="small" class="overflow-hidden">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
				<div class="w-full md:w-1/2 group">
					{feature_image && (
						<Image
							src={formatUrl(feature_image)}
							alt={feature_alt || ''}
							width={800}
							height={1200}
							class="w-full h-[400px] md:h-[600px] object-cover grayscale group-hover:grayscale-0 transition-all duration-1000"
						/>
					)}
				</div>
				<div class="w-full md:w-1/2 space-y-6">
					<h3 class="h2-serif text-balance">{feature_title}</h3>
					<div class="body-lg opacity-90 prose prose-invert" set:html={marked.parse(feature_text || '')} />
					<div class="flex justify-end pt-4">
						<a href={formatUrl(feature_link_url || '#')} class="eyebrow inline-flex items-center gap-2 border-b border-white/20 pb-1 transition-all duration-300 hover:border-terracotta hover:text-terracotta group">
							<span>{feature_link_text}</span>
							<svg class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</div>
				</div>
			</div>
		</Section>

		{/* Section 4: Expandable Content Section */}
		<Section theme="charcoal">
			<div class="max-w-6xl mx-auto space-y-16">
				<h2 class="display-serif text-center italic opacity-90">{wounds_header}</h2>
				
				<div class="grid md:grid-cols-2 gap-20 items-start">
					<div class="space-y-8 text-left pt-2">
						<h3 class="h1-serif text-balance leading-tight">{resources_title}</h3>
						<div class="body-lg opacity-80 prose prose-invert max-w-md" set:html={marked.parse(resources_text || '')} />
					</div>

					<Accordion items={resources_items || []} />
				</div>

				<div class="mt-24 pt-20 border-t border-white/10 max-w-3xl mx-auto text-center space-y-8">
					<div class="subtitle-serif prose prose-invert prose-lg max-w-none" set:html={marked.parse(adaptations_text || '')} />
					<div class="eyebrow opacity-80 prose prose-invert prose-lg max-w-none" set:html={marked.parse(trauma_therapist_text || '')} />
				</div>
			</div>
		</Section>

		{/* Section 4.5: Root Therapy Section */}
		<Section theme="cream">
			<div class="max-w-4xl mx-auto text-center space-y-10">
				<h2 class="h1-serif leading-tight">{root_title}</h2>
				<div class="max-w-3xl mx-auto body-lg opacity-90 prose text-center">
					<div set:html={marked.parse(root_content || '')} />
				</div>

				<div class="mt-24 pt-20 border-t border-black/10 max-w-3xl mx-auto text-center space-y-12">
					<h3 class="h1-serif italic">{is_this_you_title}</h3>
					
					<div class="space-y-10 body-lg opacity-90 prose text-center max-w-none">
						{is_this_you_items?.map((item: any) => (
							<div class="text-center">
								<h4 class="eyebrow text-center mb-4">{item.title}</h4>
								{item.subtitle && <p class="subtitle-serif text-center mb-4">{item.subtitle}</p>}
								<div class="text-center" set:html={marked.parse(item.body || '')} />
							</div>
						))}
					</div>
				</div>
			</div>
		</Section>

		{/* Section 5: Introduction Section */}
		<Section theme="cream">
			<div class="max-w-5xl mx-auto">
				<div class="flex flex-col md:flex-row gap-12 items-center">
					<div class="w-full md:w-1/3">
						<Image 
							src={formatUrl('images/kaylie-groenhout-headshot.jpg')} 
							alt={kaylie_alt || ''} 
							width={600}
							height={800}
							class="w-full h-auto object-cover rounded-sm shadow-md"
						/>
					</div>
					<div class="w-full md:w-2/3 space-y-8">
						<div class="max-w-2xl">
							<h2 class="display-serif mb-4">{kaylie_title}</h2>
							<p class="subtitle-serif">{kaylie_subtitle}</p>
						</div>
						
						<div class="space-y-6">
							<div class="body-lg opacity-90 max-w-3xl prose" set:html={marked.parse(kaylie_bio || '')} />
							
							<div class="flex justify-end">
								<a href={formatUrl(kaylie_link_url || '#')} class="eyebrow inline-flex items-center gap-2 hover:text-terracotta transition-colors group">
									<span>{kaylie_link_text}</span>
									<svg class="w-4 h-4 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
									</svg>
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Section>

		{/* Section 6: Specialties Summary */}
		<Section theme="alternate" class="border-t border-black/5">
			<div class="max-w-4xl mx-auto text-center space-y-12">
				<h2 class="h1-serif uppercase">My Specialties</h2>
				<div class="flex flex-col items-center gap-y-6 eyebrow opacity-80">
					{specialties?.map((spec: any, index: number) => (
						<>
							<span>{spec.name}</span>
							{index < specialties.length - 1 && <div class="w-12 h-px bg-black/20"></div>}
						</>
					))}
				</div>
			</div>
		</Section>

		{/* Section 7: How to Get Started */}
		<Section theme="none" class="bg-terracotta text-paper">
			<div class="max-w-4xl mx-auto text-center space-y-12">
				<h2 class="display-serif italic lowercase tracking-tight">{how_to_start_title}</h2>
				<div class="w-3/4 h-px bg-white/30 mx-auto"></div>
				
				<div class="grid md:grid-cols-3 gap-20 mt-20">
					{how_to_start_items?.map((item: any) => (
						<div class="space-y-6">
							<span class="display-serif opacity-40">{item.number}</span>
							<h3 class="eyebrow text-white">{item.title}</h3>
							<div class="text-sm opacity-80 leading-relaxed" set:html={marked.parse(item.text || '')} />
						</div>
					))}
				</div>
			</div>
		</Section>

		{/* Section 8: Callout Section */}
		<Section theme="cream">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
				<div class="w-full md:w-1/2 text-left space-y-8">
					<h2 class="h1-serif leading-tight text-balance">
						{callout_title}
					</h2>
					<div class="space-y-6 body-lg opacity-90 prose" set:html={marked.parse(callout_text || '')} />
				</div>
				<div class="w-full md:w-1/2">
					{callout_image && (
						<Image 
							src={formatUrl(callout_image)}
							alt={callout_alt || ''}
							width={800}
							height={600}
							class="w-full aspect-[4/3] object-cover rounded-sm shadow-xl"
						/>
					)}
				</div>
			</div>
		</Section>

		{/* Section 9: Final CTA Section */}
		<section class="flex flex-col md:flex-row min-h-[600px]">
			<div class="w-full md:w-1/2 bg-alternate flex items-center justify-center p-0">
				{hero_image && (
					<Image 
						src={formatUrl(hero_image)}
						alt={final_cta_alt || ''}
						width={1000}
						height={800}
						class="w-full h-full object-cover grayscale opacity-60"
					/>
				)}
			</div>
			<div class="w-full md:w-1/2 bg-olive text-white flex flex-col items-center justify-center p-12 text-center space-y-10">
				<div class="space-y-6">
					<h2 class="eyebrow opacity-80">{final_cta_tagline}</h2>
					<p class="display-serif italic leading-tight">{final_cta_title}</p>
				</div>
				
				<div class="pt-6">
					<Button href={cta_url || '#'} theme="white">
						{final_cta_button_text}
					</Button>
				</div>
			</div>
		</section>

		<BackToTop />
	</main>
</Layout>
