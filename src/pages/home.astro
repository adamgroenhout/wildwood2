---
import Layout from '../layouts/Layout.astro';
import homepageData from '../content/homepage.json';

const { hero_subtitle, hero_title, hero_image, cta_text, cta_url, specialties, intro_title, intro_text, feature_image, feature_title, feature_text, feature_link_text, feature_link_url } = homepageData;
const base = import.meta.env.BASE_URL;
---

<Layout title="Wildwood Psychotherapy | Trauma-Informed Therapy in Leesburg, VA">
	
	<main>
		{/* Hero Section */}
		<section class="bg-alternate relative h-screen flex flex-col justify-center items-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<img 
					src={hero_image.startsWith('http') ? hero_image : `${base}${hero_image.startsWith('/') ? hero_image.slice(1) : hero_image}`} 
					alt="Hero Background" 
					class="w-full h-full object-cover filter brightness-[0.4]"
				/>
			</div>
			
			<div class="relative z-10 text-center text-white px-4 max-w-4xl">
				<p class="text-lg uppercase tracking-widest font-sans italic font-bold mb-6 opacity-0 animate-[fadeInUp_0.8s_ease-out_forwards]">
					{hero_subtitle}
				</p>
				<h1 class="text-6xl md:text-8xl font-serif mb-10 leading-tight text-balance opacity-0 animate-[fadeInUp_0.8s_ease-out_0.2s_forwards]">
					{hero_title.split('*').map((part, i) => i % 2 === 1 ? <em class="italic">{part}</em> : part)}
				</h1>
				
				<div class="flex flex-col items-center gap-6 mt-10 opacity-0 animate-[fadeInUp_0.8s_ease-out_0.4s_forwards]">
					<a href={cta_url} class="bg-[#B17048] text-[#F9F7F0] inline-block px-6 md:px-10 py-4 text-sm font-medium hover:bg-[#965d3a] transition-all uppercase tracking-widest text-center hover:shadow-2xl active:scale-[0.98]">
						{cta_text}
					</a>
					
					<div class="flex flex-wrap justify-center gap-4">
						{specialties.map(spec => (
							<a href={`${base}${spec.url.startsWith('/') ? spec.url.slice(1) : spec.url}`} class="border border-white/40 px-6 py-2 text-sm hover:border-white transition-all duration-300 hover:bg-white/5 active:scale-95">
								{spec.name}
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		{/* Section 2: Values/Intro */}
		<section class="bg-alternate py-32 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-serif mb-10 text-balance">{intro_title}</h2>
				<p class="text-lg leading-relaxed max-w-2xl mx-auto opacity-90">
					{intro_text}
				</p>
			</div>
		</section>

		{/* Section 3: Feature Section */}
		<section class="bg-alternate py-20 overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center gap-16">
				<div class="w-full md:w-1/2 group">
					<img
						src={feature_image.startsWith('http') ? feature_image : `${base}${feature_image.startsWith('/') ? feature_image.slice(1) : feature_image}`}
						alt="Feature Image"
						class="w-full h-[400px] md:h-[600px] object-cover grayscale group-hover:grayscale-0 transition-all duration-1000"
					/>
				</div>
				<div class="w-full md:w-1/2 space-y-6">
					<h3 class="text-4xl font-serif text-balance">{feature_title}</h3>
					<p class=" leading-relaxed opacity-90">
						{feature_text}
					</p>
					<a href={`${base}${feature_link_url.startsWith('/') ? feature_link_url.slice(1) : feature_link_url}`} class="inline-block text-sm uppercase tracking-widest border-b border-white/20 pb-1 transition-all duration-300 hover:border-[#B17048] hover:text-[#B17048] link-underline">
						{feature_link_text}
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
