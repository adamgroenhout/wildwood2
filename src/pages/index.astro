---
import Layout from '../layouts/Layout.astro';
import settings from '../content/settings.json';

const { site_name, tagline, logo } = settings;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${site_name} | Coming Soon`} hideNav={true}>
	<main class="h-screen flex flex-col items-center justify-center bg-[#414224] text-white p-4">
		<div class="max-w-md w-full text-center space-y-12 animate-fade-in">
			<div class="flex flex-col items-center gap-6">
				<img 
					src={`${base}${logo.startsWith('/') ? logo.slice(1) : logo}`} 
					alt={site_name} 
					class="w-24 h-24 md:w-32 md:h-32 object-contain"
				/>
				<h1 class="text-4xl md:text-5xl font-serif tracking-tight uppercase">{site_name}</h1>
			</div>

			<div class="space-y-4">
				<p class="text-xl md:text-2xl font-serif italic opacity-90">{tagline}</p>
				<div class="h-px w-12 bg-[#B17048] mx-auto my-8"></div>
				<p class="text-sm uppercase tracking-[0.3em] font-medium opacity-60">Coming Soon</p>
			</div>

			<div class="pt-12">
				<a 
					href={`${base}admin`} 
					id="staff-login"
					class="text-[10px] uppercase tracking-widest text-white/20 hover:text-white/60 transition-colors border border-white/10 px-4 py-2 hover:border-white/30"
				>
					Staff Login
				</a>
			</div>
		</div>
	</main>
</Layout>

<script is:inline define:vars={{ base }}>
	// If already logged in, redirect to home
	const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
	if (user) {
		window.location.href = `${base}home`;
	}
</script>

<style>
	.animate-fade-in {
		animation: fadeIn 1.2s ease-out forwards;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
