---
import Layout from '../layouts/Layout.astro';
import settings from '../content/settings.json';
import { formatUrl, resolveAsset } from '../utils/paths';
import { Image } from 'astro:assets';

const { site_name, tagline, logo, coming_soon_text, staff_login_text } = settings;
const logoAsset = resolveAsset(logo || '');
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<Layout title={`${site_name} | ${coming_soon_text}`} hideNav={true}>
	<main class="h-screen flex flex-col items-center justify-center bg-olive text-paper p-6 md:p-12 theme-dark">
		<div class="max-w-md w-full text-center space-y-12 animate-fade-in">
			<div class="flex flex-col items-center gap-6">
				{logoAsset && (
					<Image 
						src={logoAsset}
						alt={site_name} 
						width={200}
						height={200}
						class="w-24 h-24 md:w-32 md:h-32 object-contain"
						loading="eager"
					/>
				)}
				<h1 class="text-4xl md:text-5xl font-serif tracking-tight uppercase">{site_name}</h1>
			</div>

			<div class="space-y-4">
				<p class="text-xl md:text-2xl font-serif italic opacity-90">{tagline}</p>
				<div class="h-px w-12 bg-terracotta mx-auto my-8"></div>
				<p class="text-sm uppercase tracking-[0.3em] font-medium opacity-60">{coming_soon_text}</p>
			</div>

			<div class="pt-12">
				<a 
					href={`${base}admin`} 
					id="staff-login"
					class="text-[10px] uppercase tracking-widest text-paper/20 hover:text-paper/60 transition-colors border border-paper/10 px-4 py-2 hover:border-paper/30 rounded-brand"
				>
					{staff_login_text}
				</a>
			</div>
		</div>
	</main>
</Layout>

<script is:inline define:vars={{ base }}>
	// If already logged in, redirect to home
	const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
	if (user) {
		window.location.href = `${base}home`;
	}
</script>

<style>
	.animate-fade-in {
		animation: fadeIn 1.2s ease-out forwards;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
