---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Accordion from '../components/Accordion.astro';
import { marked } from 'marked';
import { formatUrl } from '../utils/paths';
import { Image } from 'astro:assets';

const aboutEntry = await getEntry('pages', 'about');
const { title, seo_title, subtitle, bio, extra_sections, sections, final_cta_header, final_cta_tagline, cta_text, cta_url, headshot_alt } = aboutEntry?.data || {};
---

<Layout title={seo_title}>
	<main>
		<Section theme="alternate" padding="hero">
			<div class="max-w-4xl mx-auto">
				<h1 class="text-5xl font-serif mb-16 text-center">{title}</h1>
				
				<div class="flex flex-col md:flex-row gap-12 items-start">
					<div class="w-full md:w-1/3">
						<Image 
							src={formatUrl('images/kaylie-groenhout-headshot.jpg')} 
							alt={headshot_alt || ''} 
							width={600}
							height={800}
							class="w-full h-auto object-cover rounded-3xl shadow-md transition-all duration-700"
							loading="eager"
						/>
					</div>
					<div class="w-full md:w-2/3">
						<p class="text-xl uppercase tracking-widest font-sans italic font-bold mb-6">{subtitle}</p>
						<div class="prose prose-invert prose-lg max-w-none space-y-6">
							<div class="mb-10 space-y-4" set:html={marked(bio || '')} />
							
							<div class="mt-10">
								<Button href={cta_url || '#'} theme="terracotta">
									{cta_text}
								</Button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Section>

		{extra_sections && extra_sections.map((section: any) => (
			<Section 
				theme={section.style === 'alternate' ? 'cream' : section.style === 'dark' ? 'olive' : 'alternate'}
				class="border-t border-black/5"
			>
				<div class="max-w-4xl mx-auto text-center space-y-12">
					<div class={`space-y-4 ${section.style === 'alternate' ? 'text-olive' : ''}`}>
						<h2 class="text-4xl md:text-6xl font-serif">{section.title}</h2>
						{section.subtitle && <h3 class="text-2xl md:text-3xl font-serif italic opacity-80">{section.subtitle}</h3>}
					</div>
					
					<div class={`prose prose-lg max-w-none space-y-6 ${section.alignment === 'center' ? 'text-center' : 'text-left'} ${section.style === 'alternate' ? 'text-charcoal' : 'prose-invert'}`} set:html={marked(section.body || '')} />
				</div>
			</Section>
		))}

		<Section theme="alternate" padding="small">
			<div class="max-w-4xl mx-auto">
				<Accordion items={sections || []} theme="large" />
			</div>
		</Section>

		<Section theme="charcoal">
			<div class="max-w-4xl mx-auto text-center space-y-10">
				<div class="space-y-8">
					<h2 class="text-5xl md:text-7xl font-serif italic">{final_cta_header}</h2>
					<p class="text-xl uppercase tracking-widest opacity-80 mt-10">{final_cta_tagline}</p>
				</div>
				
				<div class="pt-8">
					<Button href={cta_url || '#'} theme="terracotta">
						{cta_text}
					</Button>
				</div>
			</div>
		</Section>
	</main>
</Layout>
