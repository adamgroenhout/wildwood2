---
import Layout from '../layouts/Layout.astro';
import aboutData from '../content/about.json';
import { marked } from 'marked';

const { title, seo_title, subtitle, bio, sections, cta_text, cta_url } = aboutData;
---

<Layout title={seo_title}>
	<main>
		<section class="bg-alternate pt-32 pb-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h1 class="text-5xl font-serif mb-10 ">{title}</h1>
				<p class="text-xl uppercase tracking-widest font-sans italic font-bold mb-6 ">{subtitle}</p>
				
				<div class="prose prose-invert prose-lg max-w-none  space-y-6">
					<div class="mb-10 space-y-4" set:html={marked(bio)} />
				</div>
			</div>
		</section>

		<section class="bg-alternate py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<div class="prose prose-invert prose-lg max-w-none  space-y-6">
					{sections.map(section => (
						<>
							<h2 class="text-3xl font-serif mt-12 mb-6 ">{section.title}</h2>
							<ul class="list-disc pl-6 space-y-2">
								{section.items.map(item => (
									<li>{item}</li>
								))}
							</ul>
						</>
					))}
				</div>

				<div class="mt-16 text-center">
					<a href={cta_url} class="bg-terracotta inline-block px-6 md:px-10 py-4 text-sm font-medium hover:bg-[#965d3a] transition-all uppercase tracking-widest text-center">
						{cta_text}
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
