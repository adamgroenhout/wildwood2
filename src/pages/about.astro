---
import Layout from '../layouts/Layout.astro';
import aboutData from '../content/about.json';
import { marked } from 'marked';

const { title, seo_title, subtitle, bio, sections, cta_text, cta_url } = aboutData;
const base = import.meta.env.BASE_URL;
---

<Layout title={seo_title}>
	<main>
		<section class="bg-alternate pt-32 pb-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h1 class="text-5xl font-serif mb-16 text-center">{title}</h1>
				
				<div class="flex flex-col md:flex-row gap-12 items-start">
					<div class="w-full md:w-1/3">
						<img 
							src={`${base}images/kaylie-groenhout-headshot.jpg`} 
							alt="Kaylie Groenhout" 
							class="w-full h-auto object-cover rounded-3xl shadow-md transition-all duration-700"
						/>
					</div>
					<div class="w-full md:w-2/3">
						<p class="text-xl uppercase tracking-widest font-sans italic font-bold mb-6">{subtitle}</p>
						<div class="prose prose-invert prose-lg max-w-none space-y-6">
							<div class="mb-10 space-y-4" set:html={marked(bio)} />
							
							<div class="mt-10">
								<a href={cta_url} class="bg-terracotta inline-block px-8 py-4 text-sm font-medium hover:bg-[#965d3a] transition-all uppercase tracking-widest text-center shadow-lg">
									{cta_text}
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-alternate py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<div class="space-y-4">
					{sections.map(section => (
						<details class="group border-b border-white/10 pb-4">
							<summary class="flex justify-between items-center cursor-pointer list-none py-4 text-3xl font-serif italic hover:text-[#B17048] transition-colors">
								<span>{section.title}</span>
								<span class="text-3xl transition-transform group-open:rotate-45 block leading-none">+</span>
							</summary>
							<div class="pt-4 pb-6 prose prose-invert prose-lg max-w-none">
								<ul class="list-disc pl-6 space-y-2">
									{section.items.map(item => (
										<li>{item}</li>
									))}
								</ul>
							</div>
						</details>
					))}
				</div>
			</div>
		</section>

		<section class="bg-[#414244] text-[#f9f7f0] py-32 px-4">
			<div class="max-w-4xl mx-auto text-center space-y-10">
				<div class="space-y-8">
					<h2 class="text-5xl md:text-7xl font-serif italic">Healing happens here.</h2>
					<p class="text-xl uppercase tracking-widest opacity-80 mt-10">Ready to get started?</p>
				</div>
				
				<div class="pt-8">
					<a href={cta_url} class="bg-terracotta inline-block px-12 py-5 text-sm font-medium hover:bg-[#965d3a] transition-all uppercase tracking-widest text-center shadow-2xl">
						{cta_text}
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
