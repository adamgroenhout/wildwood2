---
import { formatUrl } from '../utils/paths';

interface Props {
  href: string;
  theme?: 'terracotta' | 'outline' | 'white' | 'olive-outline';
  class?: string;
  [key: string]: any;
}

const { 
  href, 
  theme = 'terracotta', 
  class: className = '', 
  ...rest 
} = Astro.props;

const themeClasses = {
  terracotta: 'bg-terracotta text-paper hover:bg-terracotta-dark shadow-lg',
  outline: 'border border-white/20 text-white hover:bg-white hover:text-olive hover:shadow-lg',
  white: 'border border-white text-white hover:bg-white hover:text-olive shadow-lg',
  'olive-outline': 'border border-olive text-olive hover:bg-olive hover:text-paper',
};

const baseClasses = 'inline-block px-10 py-4 text-sm font-medium transition-all uppercase tracking-widest text-center active:scale-95';
---

<a 
  href={formatUrl(href)} 
  class:list={[baseClasses, themeClasses[theme], className]}
  {...rest}
>
  <slot />
</a>
