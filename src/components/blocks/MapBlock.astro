---
import Section from '../Section.astro';
import { marked } from 'marked';
import { getEntry } from 'astro:content';

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    body?: string;
    address?: string;
    phone?: string;
    email?: string;
    map_embed_url?: string;
    map_link_url?: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate';
    padding?: 'standard' | 'large' | 'small' | 'top-only' | 'bottom-only' | 'x-only' | 'none';
    alignment?: 'left' | 'center';
  }
}

const { data } = Astro.props;

// Fetch global contact settings
const settingsEntry = await getEntry('settings', 'settings');
const globalContact = settingsEntry?.data?.contact || {};

// Default map embed for 19 Wirt St SW, Suite 205, Leesburg, VA 20175
const defaultMapEmbed = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3099.9328243616656!2d-77.5684742!3d39.1121543!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89b6164295d86289%3A0x673160e1844b256!2s19%20Wirt%20St%20SW%20%23205%2C%20Leesburg%2C%20VA%2020175!5e0!3m2!1sen!2sus!4v1710255375545!5m2!1sen!2sus";

const mapEmbedUrl = data.map_embed_url || defaultMapEmbed;
const mapLinkUrl = data.map_link_url || "https://maps.app.goo.gl/MnMZViMsUDX4wTj28";

const address = data.address || globalContact.address;
const phone = data.phone || globalContact.phone;
const email = data.email || globalContact.email;
---

<Section theme={data.theme || 'cream'} padding={data.padding || 'standard'}>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      
      {/* Contact Information Column */}
      <div class="lg:col-span-5 space-y-10">
        <div class="space-y-6">
          {data.subtitle && <p class="eyebrow text-terracotta">{data.subtitle}</p>}
          <h2 class="h2-serif">{data.title || 'Visit the Office'}</h2>
          
          {data.body && (
            <div class="body-lg opacity-85 prose text-pretty" set:html={marked.parse(data.body)} />
          )}
        </div>

        <div class="space-y-8">
          {address && (
            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1">
                <svg class="w-6 h-6 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="eyebrow text-xs mb-2 opacity-60">Location</h3>
                <p class="body-lg font-medium whitespace-pre-line leading-snug">{address}</p>
              </div>
            </div>
          )}

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-8">
            {phone && (
              <div class="flex gap-4">
                <div class="flex-shrink-0 mt-1">
                  <svg class="w-6 h-6 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="eyebrow text-xs mb-2 opacity-60">Phone</h3>
                  <p class="body-lg font-medium">{phone}</p>
                </div>
              </div>
            )}

            {email && (
              <div class="flex gap-4">
                <div class="flex-shrink-0 mt-1">
                  <svg class="w-6 h-6 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="eyebrow text-xs mb-2 opacity-60">Email</h3>
                  <a href={`mailto:${email}`} class="body-lg font-medium hover:text-terracotta transition-colors">{email}</a>
                </div>
              </div>
            )}
          </div>
        </div>

        <div class="pt-4">
          <a 
            href={mapLinkUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-outline w-full sm:w-auto"
          >
            Get Directions
          </a>
        </div>
      </div>

      {/* Map Column */}
      <div class="lg:col-span-7 h-[450px] lg:h-[600px] w-full relative group">
        <div class="absolute inset-0 bg-olive/5 rounded-brand -rotate-1 translate-x-2 translate-y-2 group-hover:rotate-0 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-700 ease-out"></div>
        <div class="relative h-full w-full overflow-hidden rounded-brand shadow-soft group-hover:shadow-elevated transition-all duration-700 border border-olive/10">
          <iframe
            src={mapEmbedUrl}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="grayscale-[0.2] contrast-[1.1] brightness-[1.05]"
          ></iframe>
        </div>
      </div>

    </div>
  </div>
</Section>

<style>
  iframe {
    filter: sepia(10%) hue-rotate(-10deg) saturate(90%);
  }
</style>
