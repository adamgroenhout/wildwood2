---
import Section from '../Section.astro';
import { marked } from 'marked';

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    body: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'alternate';
    alignment?: 'left' | 'center';
    padding?: 'standard' | 'large' | 'small' | 'top-only' | 'bottom-only' | 'x-only' | 'none';
  }
}

const { data } = Astro.props;
---

<Section theme={data.theme || 'alternate'} padding={data.padding || 'standard'}>
  <div class="max-w-4xl mx-auto space-y-8">
    {(data.title || data.subtitle) && (
      <div class="space-y-4 text-center max-w-3xl mx-auto">
        {data.subtitle && (
          <p class="eyebrow text-terracotta">
            {data.subtitle}
          </p>
        )}
        {data.title && (
          <h2 class="h2-serif text-balance leading-tight">
            {data.title}
          </h2>
        )}
      </div>
    )}
    
    {data.body && (
      <div class:list={[
        "body-lg opacity-85 prose mx-auto text-left",
        !data.title && data.subtitle ? 'mt-4' : ''
      ]} set:html={marked.parse(data.body)} />
    )}
  </div>
</Section>
