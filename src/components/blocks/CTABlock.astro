---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { formatUrl, resolveAsset } from '../../utils/paths';
import { Image } from 'astro:assets';

interface Props {
  data: {
    title: string;
    tagline?: string;
    button_text: string;
    button_url: string;
    image?: string;
    image_alt?: string;
    theme?: 'sage' | 'cream' | 'sand' | 'paper' | 'charcoal' | 'olive' | 'terracotta' | 'alternate';
    layout?: 'split' | 'centered';
  }
}

const { data } = Astro.props;
const themeClass = `bg-${data.theme || 'olive'}`;
const isDark = ['olive', 'terracotta', 'charcoal'].includes(data.theme || 'olive');
const buttonTheme = isDark ? 'white' : 'terracotta';
const asset = resolveAsset(data.image || '');
---

{data.layout === 'split' ? (
  <Section theme="none" padding="none" class="flex flex-col md:flex-row min-h-[600px] relative z-10">
    <div class="w-full md:w-1/2 bg-alternate flex items-center justify-center p-0 overflow-hidden">
      {asset && (
        <Image 
          src={asset}
          alt={data.image_alt || ''}
          width={1000}
          height={800}
          class="w-full h-full object-cover grayscale opacity-60"
        />
      )}
    </div>
    <div class={`w-full md:w-1/2 ${themeClass} flex flex-col items-center justify-center p-12 text-center space-y-10 ${isDark ? 'theme-dark' : ''} relative z-20`}>
      <div class="space-y-6">
        {data.tagline && <h2 class="eyebrow opacity-80 text-pretty text-center">{data.tagline}</h2>}
        <h2 class="display-serif italic leading-tight whitespace-pre-wrap text-pretty relative z-30 text-center">{data.title.split('\n').map((line, i) => (
            <Fragment key={i}>
              {i > 0 && <br />}
              {line}
            </Fragment>
          ))}</h2>
      </div>
      <div class="pt-6">
        <Button href={data.button_url} theme={buttonTheme}>
          {data.button_text}
        </Button>
      </div>
    </div>
  </Section>
) : (
  <Section theme={data.theme || 'olive'} class={`text-center space-y-10 ${isDark ? 'theme-dark' : ''} relative z-10`}>
    <div class="max-w-3xl mx-auto space-y-6 relative z-20">
      {data.tagline && <h2 class="eyebrow opacity-80 text-pretty text-center">{data.tagline}</h2>}
      <h2 class="display-serif italic leading-tight whitespace-pre-wrap text-pretty relative z-30 text-center">{data.title.split('\n').map((line, i) => (
          <Fragment key={i}>
            {i > 0 && <br />}
            {line}
          </Fragment>
        ))}</h2>
    </div>
    <div class="pt-6 relative z-20">
      <Button href={data.button_url} theme={buttonTheme}>
        {data.button_text}
      </Button>
    </div>
  </Section>
)}
