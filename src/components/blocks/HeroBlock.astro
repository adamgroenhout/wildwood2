---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { formatUrl } from '../../utils/paths';
import { Image } from 'astro:assets';

interface Props {
  data: {
    hero_title: string;
    hero_subtitle?: string;
    hero_image?: string;
    hero_alt?: string;
    cta_text?: string;
    cta_url?: string;
    theme?: 'dark' | 'light' | 'terracotta' | 'olive';
    alignment?: 'center' | 'left';
    specialties?: Array<{ name: string; url: string }>;
  }
}

const { data } = Astro.props;
const themeClass = data.theme === 'dark' || data.theme === 'olive' ? 'bg-olive theme-dark' : 'bg-paper theme-light';
const alignmentClass = data.alignment === 'left' ? 'text-left items-start' : 'text-center items-center';
---

<Section theme="none" padding="hero" class={`relative min-h-screen flex flex-col justify-center items-center overflow-hidden ${themeClass}`}>
  <div class="absolute inset-0 z-0">
    {data.hero_image && (
      <Image 
        src={formatUrl(data.hero_image)}
        alt={data.hero_alt || ''} 
        width={1920}
        height={1080}
        class={`w-full h-full object-cover filter transition-transform duration-[10s] ease-linear group-hover:scale-110 ${data.theme === 'dark' || data.theme === 'olive' ? 'brightness-[0.35]' : 'brightness-[0.85]'}`}
        style="animation: slowZoom 60s linear infinite alternate;"
        loading="eager"
      />
    )}
  </div>
  
  <div class={`relative z-10 px-4 max-w-5xl flex flex-col ${alignmentClass} w-full`}>
    {data.hero_subtitle && (
      <p class="eyebrow mb-10 animate-[fadeInUp_1s_var(--ease-gentle)_forwards] opacity-0" style="animation-delay: 0.1s;">
        {data.hero_subtitle}
      </p>
    )}
    
    {data.hero_title && (
      <h1 class={`display-serif mb-10 text-balance animate-[fadeInUp_1s_var(--ease-gentle)_forwards] opacity-0 ${data.alignment === 'left' ? 'text-left' : 'text-center'}`} style="animation-delay: 0.3s;">
        {data.hero_title.split('*').map((part: string, i: number) => i % 2 === 1 ? <em class="italic serif-italic">{part}</em> : part)}
      </h1>
    )}
    
    {(data.cta_text || data.specialties?.length) && (
      <div class={`flex flex-col gap-10 mt-4 animate-[fadeInUp_1s_var(--ease-gentle)_forwards] opacity-0 ${alignmentClass}`} style="animation-delay: 0.5s;">
        {data.cta_text && data.cta_url && (
          <Button href={data.cta_url} theme={data.theme === 'dark' || data.theme === 'olive' ? 'terracotta' : 'terracotta'}>
            {data.cta_text}
          </Button>
        )}
        
        {data.specialties && data.specialties.length > 0 && (
          <div class={`flex flex-wrap gap-6 ${data.alignment === 'left' ? 'justify-start' : 'justify-center'}`}>
            {data.specialties.map((spec: any, idx: number) => (
              <a 
                href={formatUrl(spec.url)} 
                class="eyebrow text-[10px] border border-current/20 px-5 py-2 hover:border-current/60 transition-all duration-500 hover:bg-current/5 active:scale-95 rounded-brand"
              >
                {spec.name}
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</Section>

<style>
  @keyframes slowZoom {
    from { transform: scale(1) translateZ(0); }
    to { transform: scale(1.15) translateZ(0); }
  }
</style>
