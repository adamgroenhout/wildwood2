---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { formatUrl, resolveAsset } from '../../utils/paths';
import { Image } from 'astro:assets';

interface Props {
  data: {
    hero_title: string;
    hero_subtitle?: string;
    hero_image?: string;
    hero_alt?: string;
    cta_text?: string;
    cta_url?: string;
    theme?: 'dark' | 'light' | 'terracotta' | 'olive';
    alignment?: 'center' | 'left';
    specialties?: Array<{ name: string; url: string }>;
  }
}

const { data } = Astro.props;
const themeClass = data.theme === 'dark' || data.theme === 'olive' ? 'bg-olive theme-dark' : 'bg-paper theme-light';
const alignmentClass = data.alignment === 'left' ? 'text-left items-start' : 'text-center items-center';

const heroAsset = resolveAsset(data.hero_image || '');
---

<Section theme="none" padding="hero" class={`relative min-h-screen flex flex-col justify-center items-center overflow-hidden ${themeClass}`}>
  <div class="absolute inset-0 z-0">
    {heroAsset && (
      <Image 
        src={heroAsset}
        alt={data.hero_alt || ''} 
        width={1920}
        height={1080}
        class={`w-full h-full object-cover filter transition-transform duration-[10s] ease-linear group-hover:scale-110 ${data.theme === 'dark' || data.theme === 'olive' ? 'brightness-[0.35]' : 'brightness-[0.85]'}`}
        style="animation: slowZoom 60s linear infinite alternate;"
        loading="eager"
      />
    )}
  </div>
  
  <div class={`relative z-10 max-w-5xl flex flex-col ${alignmentClass} w-full`}>
    {data.hero_subtitle && (
      <p class="eyebrow mb-10 animate-[fadeInUp_1s_var(--ease-gentle)_forwards] opacity-0 text-pretty" style="animation-delay: 0.1s;">
        {data.hero_subtitle}
      </p>
    )}
    
    {data.hero_title && (
      <h1 class={`display-serif mb-10 animate-[fadeInUp_1s_var(--ease-gentle)_forwards] opacity-0 whitespace-pre-wrap text-pretty ${data.alignment === 'left' ? 'text-left' : 'text-center'}`} style="animation-delay: 0.3s;">{data.hero_title.split('\n').map((line, lineIdx) => (
          <Fragment key={lineIdx}>
            {lineIdx > 0 && <br />}
            {line.split('<br>').map((subLine, subLineIdx) => (
              <Fragment key={subLineIdx}>
                {subLineIdx > 0 && <br />}
                {subLine.split('*').map((part: string, i: number) => i % 2 === 1 ? <em class="italic serif-italic">{part}</em> : part)}
              </Fragment>
            ))}
          </Fragment>
        ))}</h1>
    )}
    
    {(data.cta_text || data.specialties?.length) && (
      <div class={`flex flex-col gap-10 mt-4 animate-[fadeInUp_1s_var(--ease-gentle)_forwards] opacity-0 ${alignmentClass}`} style="animation-delay: 0.5s;">
        {data.cta_text && data.cta_url && (
          <Button href={data.cta_url} theme={data.theme === 'dark' || data.theme === 'olive' ? 'terracotta' : 'terracotta'}>
            {data.cta_text}
          </Button>
        )}
        
        {data.specialties && data.specialties.length > 0 && (
          <div class={`flex flex-wrap gap-4 sm:gap-6 mt-4 ${data.alignment === 'left' ? 'justify-start' : 'justify-center'}`}>
            {data.specialties.map((spec: any, idx: number) => (
              <a 
                href={formatUrl(spec.url)} 
                class={`btn ${data.theme === 'dark' || data.theme === 'olive' ? 'btn-white' : 'btn-outline'} text-[10px] sm:text-xs !px-6 !py-3 backdrop-blur-sm`}
              >
                {spec.name}
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</Section>

<style>
  @keyframes slowZoom {
    from { transform: scale(1) translateZ(0); }
    to { transform: scale(1.15) translateZ(0); }
  }
</style>
