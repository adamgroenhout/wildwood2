---
import { getEntry } from 'astro:content';
import { formatUrl } from '../utils/paths';

const settingsEntry = await getEntry('settings', 'settings');
const { site_name, tagline, land_acknowledgment, footer_columns, staff_logout_text, staff_login_text, copyright_text } = settingsEntry?.data || {};

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-cream text-charcoal border-t border-black/5 py-20 px-6 md:px-12 lg:px-16">
	<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-10">
		<div>
			<a href={formatUrl('')} class="text-3xl tracking-tight uppercase font-serif text-olive">{site_name?.split(' ')[0]}</a>
			<p class="mt-4 text-sm opacity-70 text-pretty">{tagline}</p>
		</div>
		<div class={`grid grid-cols-2 md:grid-cols-${footer_columns?.length || 2} gap-10`}>
			{footer_columns?.map(column => (
				<div>
					<h3 class="eyebrow mb-4 opacity-40">{column.title}</h3>
					<ul class="space-y-2 text-sm opacity-70">
						{column.links.map(link => (
							<li><a href={formatUrl(link.href)} class="hover:text-terracotta transition-colors link-underline">{link.name}</a></li>
						))}
					</ul>
				</div>
			))}
		</div>
	</div>
	<div class="max-w-7xl mx-auto mt-20 pt-10 border-t border-black/5 space-y-4">
		{land_acknowledgment && (
			<div class="text-[10px] opacity-40 italic max-w-2xl leading-relaxed text-pretty" set:html={land_acknowledgment} />
		)}
		<div class="flex justify-between items-center text-xs opacity-40">
			<p>&copy; {year} {site_name}. {copyright_text || 'All rights reserved.'}</p>
			<div>
				<a 
					id="login-link" 
					href={`${base}admin`}
					class="hover:text-terracotta transition-colors eyebrow text-[10px]"
				>
					{staff_login_text || 'Staff Login'}
				</a>
				<button 
					id="logout-button" 
					class="hidden hover:text-terracotta transition-colors eyebrow text-[10px]"
				>
					{staff_logout_text || 'Staff Logout'}
				</button>
			</div>
		</div>
	</div>
</footer>

<script is:inline define:vars={{ base }}>
	// Check if user is logged in to show logout button instead of login link
	const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
	const loginLink = document.getElementById('login-link');
	const logoutBtn = document.getElementById('logout-button');
	
	if (user && logoutBtn && loginLink) {
		loginLink.classList.add('hidden');
		logoutBtn.classList.remove('hidden');
		logoutBtn.addEventListener('click', () => {
			localStorage.removeItem('decap-cms-user');
			localStorage.removeItem('netlify-cms-user');
			window.location.href = base;
		});
	}
</script>
