---
import settings from '../content/settings.json';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;

const { site_name, tagline, contact } = settings;
---

<footer class="bg-[#414244] border-t border-white/5 py-20 px-4">
	<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-10">
		<div>
			<a href={base} class="text-3xl tracking-tight uppercase font-serif text-white">{site_name.split(' ')[0]}</a>
			<p class="mt-4 text-sm text-white/50">{tagline}</p>
		</div>
		<div class="grid grid-cols-2 md:grid-cols-4 gap-10">
			<div>
				<h3 class="text-xs uppercase tracking-widest font-bold mb-4 text-white/40">Practice</h3>
				<ul class="space-y-2 text-sm text-white/60">
					<li><a href={`${base}about`} class="hover:text-white transition-colors link-underline">About</a></li>
					<li><a href={`${base}faqs`} class="hover:text-white transition-colors link-underline">FAQs</a></li>
					<li><a href={`${base}events`} class="hover:text-white transition-colors link-underline">Events</a></li>
				</ul>
			</div>
			<div>
				<h3 class="text-xs uppercase tracking-widest font-bold mb-4 text-white/40">Specialties</h3>
				<ul class="space-y-2 text-sm text-white/60">
					<li><a href={`${base}anxiety-and-perfectionism`} class="hover:text-white transition-colors link-underline">Anxiety</a></li>
					<li><a href={`${base}relationships`} class="hover:text-white transition-colors link-underline">Relationships</a></li>
					<li><a href={`${base}trauma-and-emdr`} class="hover:text-white transition-colors link-underline">Trauma + EMDR</a></li>
				</ul>
			</div>
			<div>
				<h3 class="text-xs uppercase tracking-widest font-bold mb-4 text-white/40">Legal</h3>
				<ul class="space-y-2 text-sm text-white/60">
					<li><a href={`${base}good-faith-estimate`} class="hover:text-white transition-colors link-underline">Good Faith Estimate</a></li>
					<li><a href={`${base}privacy`} class="hover:text-white transition-colors link-underline">Privacy Policy</a></li>
				</ul>
			</div>
			<div>
				<h3 class="text-xs uppercase tracking-widest font-bold mb-4 text-white/40">Contact</h3>
				<ul class="space-y-2 text-sm text-white/60">
					<li><a href={contact.consultation_url} class="hover:text-white transition-colors link-underline">Schedule Consultation</a></li>
				</ul>
			</div>
		</div>
	</div>
	<div class="max-w-7xl mx-auto mt-20 pt-10 border-t border-white/5 flex justify-between items-center text-xs text-white/30">
		<p>&copy; {year} {site_name}. All rights reserved.</p>
		<button 
			id="logout-button" 
			class="hidden hover:text-white transition-colors uppercase tracking-widest text-[10px]"
		>
			Staff Logout
		</button>
	</div>
</footer>

<script is:inline define:vars={{ base }}>
	// Check if user is logged in to show logout button
	const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
	const logoutBtn = document.getElementById('logout-button');
	
	if (user && logoutBtn) {
		logoutBtn.classList.remove('hidden');
		logoutBtn.addEventListener('click', () => {
			localStorage.removeItem('decap-cms-user');
			localStorage.removeItem('netlify-cms-user');
			window.location.href = base;
		});
	}
</script>
