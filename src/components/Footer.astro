---
import { getEntry } from 'astro:content';
import { formatUrl } from '../utils/paths';

const settingsEntry = await getEntry('pages', 'settings');
const { site_name, tagline, land_acknowledgment, footer_columns } = settingsEntry?.data || {};

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-cream text-charcoal border-t border-black/5 py-20 px-4">
	<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-10">
		<div>
			<a href={formatUrl('')} class="text-3xl tracking-tight uppercase font-serif text-olive">{site_name?.split(' ')[0]}</a>
			<p class="mt-4 text-sm opacity-70">{tagline}</p>
		</div>
		<div class={`grid grid-cols-2 md:grid-cols-${footer_columns?.length || 2} gap-10`}>
			{footer_columns?.map(column => (
				<div>
					<h3 class="text-xs uppercase tracking-widest font-bold mb-4 opacity-40">{column.title}</h3>
					<ul class="space-y-2 text-sm opacity-70">
						{column.links.map(link => (
							<li><a href={formatUrl(link.href)} class="hover:text-terracotta transition-colors link-underline">{link.name}</a></li>
						))}
					</ul>
				</div>
			))}
		</div>
	</div>
	<div class="max-w-7xl mx-auto mt-20 pt-10 border-t border-black/5 space-y-4">
		<div class="text-[10px] opacity-40 italic max-w-2xl leading-relaxed">
			Land Acknowledgment: {land_acknowledgment}
		</div>
		<div class="flex justify-between items-center text-xs opacity-40">
			<p>&copy; {year} {site_name}. All rights reserved.</p>
			<button 
				id="logout-button" 
				class="hidden hover:text-terracotta transition-colors uppercase tracking-widest text-[10px]"
			>
				Staff Logout
			</button>
		</div>
	</div>
</footer>

<script is:inline define:vars={{ base }}>
	// Check if user is logged in to show logout button
	const user = localStorage.getItem('decap-cms-user') || localStorage.getItem('netlify-cms-user');
	const logoutBtn = document.getElementById('logout-button');
	
	if (user && logoutBtn) {
		logoutBtn.classList.remove('hidden');
		logoutBtn.addEventListener('click', () => {
			localStorage.removeItem('decap-cms-user');
			localStorage.removeItem('netlify-cms-user');
			window.location.href = base;
		});
	}
</script>
