---
import settings from '../content/settings.json';

const base = import.meta.env.BASE_URL;

const { site_name, logo, navigation } = settings;

// Helper to format URLs correctly with base path
const formatUrl = (url: string) => {
  if (url === '#' || url.startsWith('http')) return url;
  if (url.startsWith(base)) return url;
  return `${base}${url.startsWith('/') ? url.slice(1) : url}`;
};
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#294b27]/95 backdrop-blur-sm border-b border-white/5">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-20">
			<div class="flex-shrink-0">
				<a href={`${base}home`} id="logo-link" class="flex items-center gap-3 text-2xl tracking-tight uppercase font-serif text-white">
					<img src={formatUrl(logo)} alt={`${site_name} Logo`} class="h-12 w-12 object-contain" />
					<span>{site_name}</span>
				</a>
			</div>
			
			<!-- Desktop Navigation -->
			<nav class="hidden lg:flex space-x-10 items-center">
				{navigation.map(item => (
					<div class="relative group">
						<a href={formatUrl(item.href)} class="text-sm font-medium text-white/70 hover:text-white transition-colors link-underline uppercase tracking-wider">
							{item.name}
							{item.subItems && (
								<svg class="ml-1 w-3 h-3 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							)}
						</a>
						{item.subItems && (
							<div class="absolute left-0 mt-2 w-56 bg-[#294b27] border border-white/10 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0">
								{item.subItems.map(subItem => (
									<a href={formatUrl(subItem.href)} class="block px-4 py-3 text-sm text-white/70 hover:bg-white/5 hover:text-white transition-colors uppercase tracking-wider">
										{subItem.name}
									</a>
								))}
							</div>
						)}
					</div>
				))}
				<a href={`${base}contact`} class="inline-flex items-center px-6 py-2 border border-white/20 text-sm font-medium text-white hover:bg-white hover:text-[#294b27] transition-all duration-300 hover:shadow-lg uppercase tracking-wider">
					Contact
				</a>
			</nav>

			<!-- Mobile Menu Button -->
			<div class="lg:hidden flex items-center">
				<button id="mobile-menu-button" type="button" class="text-white/70 hover:text-white p-2 transition-transform active:scale-95" aria-label="Toggle menu">
					<svg id="menu-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16" />
					</svg>
					<svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Mobile Navigation Drawer -->
	<div id="mobile-menu" class="hidden lg:hidden bg-[#294b27] border-t border-white/10 px-4 pt-2 pb-6 space-y-1 shadow-2xl transition-all duration-300">
		{navigation.map(item => (
			<div class="border-b border-white/5 last:border-0">
				<div class="flex items-center justify-between">
					<a href={formatUrl(item.href)} class="block px-3 py-4 text-base font-medium text-white hover:text-white/80 transition-colors uppercase tracking-wider">
						{item.name}
					</a>
					{item.subItems && (
						<button class="mobile-submenu-toggle p-3 text-white/50 hover:text-white transition-colors">
							<svg class="w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</button>
					)}
				</div>
				{item.subItems && (
					<div class="hidden pl-4 pr-2 pb-2 space-y-1 bg-black/10 rounded-lg mb-2 overflow-hidden transition-all duration-300">
						{item.subItems.map(subItem => (
							<a href={formatUrl(subItem.href)} class="block px-4 py-3 text-sm text-white/70 hover:text-white border-l border-white/10 ml-2 uppercase tracking-wider">
								{subItem.name}
							</a>
						))}
					</div>
				)}
			</div>
		))}
		<div class="pt-6">
			<a href={`${base}contact`} class="block text-center px-6 py-4 bg-[#B17048] text-white text-base font-medium hover:bg-[#965d3a] transition-all uppercase tracking-widest shadow-lg active:scale-[0.98]">
				Contact
			</a>
		</div>
	</div>
</header>

<script>
	function initMenu() {
		const button = document.getElementById('mobile-menu-button');
		const menu = document.getElementById('mobile-menu');
		const menuIcon = document.getElementById('menu-icon');
		const closeIcon = document.getElementById('close-icon');
		const header = document.querySelector('header');

		// Scroll listener for header shadow
		window.addEventListener('scroll', () => {
			if (header) {
				if (window.scrollY > 10) {
					header.classList.add('shadow-xl', 'border-white/10');
					header.classList.remove('border-white/5');
				} else {
					header.classList.remove('shadow-xl', 'border-white/10');
					header.classList.add('border-white/5');
				}
			}
		}, { passive: true });

		if (button && menu && menuIcon && closeIcon) {
			button.onclick = () => {
				const isHidden = menu.classList.contains('hidden');
				if (isHidden) {
					menu.classList.remove('hidden');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					document.body.style.overflow = 'hidden'; // Prevent scroll when menu is open
				} else {
					menu.classList.add('hidden');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					document.body.style.overflow = '';
				}
			};
		}

		// Submenu toggles for mobile
		document.querySelectorAll('.mobile-submenu-toggle').forEach(toggle => {
			toggle.onclick = (e) => {
				e.preventDefault();
				const submenu = toggle.parentElement?.nextElementSibling;
				const icon = toggle.querySelector('svg');
				if (submenu && icon) {
					const isHidden = submenu.classList.toggle('hidden');
					icon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
				}
			};
		});
	}

	// Initialize on first load
	initMenu();

	// If using view transitions, re-initialize on page changes
	document.addEventListener('astro:after-swap', initMenu);
</script>
