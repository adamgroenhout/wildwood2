---
import { getEntry } from 'astro:content';
import { formatUrl } from '../utils/paths';
import { Image } from 'astro:assets';
import Button from './Button.astro';

const settingsEntry = await getEntry('settings', 'settings');
const { site_name, logo, navigation, header_cta_text, header_cta_href } = settingsEntry?.data || {};
---

<header class="fixed top-0 left-0 right-0 z-50 bg-olive/0 transition duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] border-b border-transparent pointer-events-none">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pointer-events-auto">
		<div class="flex justify-between items-center h-20 md:h-24 transition-[height] duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]" id="header-inner">
			<div class="flex-shrink-0">
				<a href={formatUrl('home')} id="logo-link" class="flex items-center gap-3 text-lg md:text-xl tracking-tight uppercase text-paper font-serif">
					<Image 
						src={formatUrl(logo)} 
						alt={`${site_name} Logo`} 
						width={48} 
						height={48} 
						class="h-10 w-10 md:h-12 md:w-12 object-contain" 
						loading="eager" 
					/>
					<span class="max-w-[120px] md:max-w-none leading-none whitespace-nowrap">{site_name}</span>
				</a>
			</div>

			<!-- Desktop Navigation -->
			<nav class="hidden lg:flex space-x-6 xl:space-x-8 items-center">
				{navigation?.map(item => (
					<div class="relative group">
						<a href={formatUrl(item.href)} class="eyebrow text-paper/70 hover:text-paper transition-colors link-underline">
							{item.name}
							{item.subItems && (
								<svg class="ml-1 w-3 h-3 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							)}
						</a>
						{item.subItems && (
							<div class="absolute left-0 mt-2 w-56 bg-olive border border-paper/10 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0 pointer-events-none group-hover:pointer-events-auto before:content-[''] before:absolute before:-top-2 before:left-0 before:right-0 before:h-2">
								{item.subItems.map(subItem => (
									<a href={formatUrl(subItem.href)} class="block px-4 py-3 eyebrow text-paper/70 hover:bg-paper/5 hover:text-paper transition-colors">
										{subItem.name}
									</a>
								))}
							</div>
						)}
					</div>
				))}
				<Button href={header_cta_href || '#'} theme="white" class="!px-6 !py-2">
					{header_cta_text}
				</Button>
			</nav>

			<!-- Mobile Menu Button -->
			<div class="lg:hidden flex items-center">
				<button id="mobile-menu-button" type="button" class="text-paper/70 hover:text-paper p-2 transition-transform active:scale-95" aria-label="Toggle menu">
					<svg id="menu-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16" />
					</svg>
					<svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Mobile Navigation Drawer -->
	<div id="mobile-menu" class="hidden lg:hidden bg-olive border-t border-paper/10 px-4 pt-2 pb-6 space-y-1 shadow-2xl transition-all duration-300 pointer-events-none">
		{navigation?.map(item => (
			<div class="border-b border-paper/5 last:border-0">
				<div class="flex items-center justify-between">
					<a href={formatUrl(item.href)} class="block px-3 py-4 eyebrow text-paper hover:text-paper/80 transition-colors">
						{item.name}
					</a>
					{item.subItems && (
						<button class="mobile-submenu-toggle p-3 text-paper/50 hover:text-paper transition-colors">
							<svg class="w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</button>
					)}
				</div>
				{item.subItems && (
					<div class="hidden pl-4 pr-2 pb-2 space-y-1 bg-black/10 rounded-brand mb-2 overflow-hidden transition-all duration-300">
						{item.subItems.map(subItem => (
							<a href={formatUrl(subItem.href)} class="block px-4 py-3 eyebrow text-paper/70 hover:text-paper border-l border-paper/10 ml-2">
								{subItem.name}
							</a>
						))}
					</div>
				)}
			</div>
		))}
		<div class="pt-6 px-3">
			<a href={formatUrl(header_cta_href)} class="btn btn-terracotta px-6 py-3">
				{header_cta_text}
			</a>
		</div>
	</div>
</header>

<script>
	function initMenu() {
		const button = document.getElementById('mobile-menu-button');
		const menu = document.getElementById('mobile-menu');
		const menuIcon = document.getElementById('menu-icon');
		const closeIcon = document.getElementById('close-icon');
		const header = document.querySelector('header');
		const headerInner = document.getElementById('header-inner');

		// Scroll listener for header shadow
		window.addEventListener('scroll', () => {
			if (header && headerInner) {
				if (window.scrollY > 20) {
					header.classList.add('bg-olive/95', 'backdrop-blur-md', 'border-paper/10', 'shadow-soft');
					header.classList.remove('bg-olive/0', 'border-transparent');
					headerInner.classList.remove('h-20', 'md:h-24');
					headerInner.classList.add('h-16', 'md:h-20');
				} else {
					header.classList.remove('bg-olive/95', 'backdrop-blur-md', 'border-paper/10', 'shadow-soft');
					header.classList.add('bg-olive/0', 'border-transparent');
					headerInner.classList.add('h-20', 'md:h-24');
					headerInner.classList.remove('h-16', 'md:h-20');
				}
			}
		}, { passive: true });

		if (button && menu && menuIcon && closeIcon) {
			button.onclick = () => {
				const isHidden = menu.classList.contains('hidden');
				if (isHidden) {
					menu.classList.remove('hidden', 'pointer-events-none');
					menu.classList.add('pointer-events-auto');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					document.body.style.overflow = 'hidden'; // Prevent scroll when menu is open
				} else {
					menu.classList.add('hidden', 'pointer-events-none');
					menu.classList.remove('pointer-events-auto');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					document.body.style.overflow = '';
				}
			};
		}

		// Submenu toggles for mobile
		document.querySelectorAll('.mobile-submenu-toggle').forEach(toggle => {
			toggle.onclick = (e) => {
				e.preventDefault();
				const submenu = (toggle as HTMLElement).parentElement?.nextElementSibling;
				const icon = toggle.querySelector('svg');
				if (submenu && icon) {
					const isHidden = submenu.classList.toggle('hidden');
					icon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
				}
			};
		});
	}

	// Initialize on first load
	initMenu();

	// If using view transitions, re-initialize on page changes
	document.addEventListener('astro:after-swap', initMenu);
</script>
