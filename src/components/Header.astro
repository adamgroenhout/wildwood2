---
import { getEntry } from 'astro:content';
import { formatUrl } from '../utils/paths';
import { Image } from 'astro:assets';

const settingsEntry = await getEntry('pages', 'settings');
const { site_name, logo, navigation, header_cta_text, header_cta_href } = settingsEntry?.data || {};
---

<header class="fixed top-0 left-0 right-0 z-50 bg-olive/95 backdrop-blur-sm border-b border-white/5">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-20">
			<div class="flex-shrink-0">
				<a href={formatUrl('home')} id="logo-link" class="flex items-center gap-3 text-lg md:text-xl tracking-tight uppercase text-white" style="font-family: var(--font-serif);">
					<Image 
						src={formatUrl(logo)} 
						alt={`${site_name} Logo`} 
						width={48} 
						height={48} 
						class="h-10 w-10 md:h-12 md:w-12 object-contain" 
						loading="eager" 
					/>
					<span class="max-w-[120px] md:max-w-none leading-none whitespace-nowrap">{site_name}</span>
				</a>
			</div>

			<!-- Desktop Navigation -->
			<nav class="hidden lg:flex space-x-6 xl:space-x-8 items-center">
				{navigation?.map(item => (
					<div class="relative group">
						<a href={formatUrl(item.href)} class="eyebrow text-white/70 hover:text-white transition-colors link-underline">
							{item.name}
							{item.subItems && (
								<svg class="ml-1 w-3 h-3 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							)}
						</a>
						{item.subItems && (
							<div class="absolute left-0 mt-2 w-56 bg-olive border border-white/10 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0">
								{item.subItems.map(subItem => (
									<a href={formatUrl(subItem.href)} class="block px-4 py-3 eyebrow text-white/70 hover:bg-white/5 hover:text-white transition-colors">
										{subItem.name}
									</a>
								))}
							</div>
						)}
					</div>
				))}
				<a href={formatUrl(header_cta_href)} class="inline-flex items-center px-6 py-2 border border-white/20 eyebrow text-white hover:bg-white hover:text-olive transition-all duration-300 hover:shadow-lg">
					{header_cta_text}
				</a>
			</nav>

			<!-- Mobile Menu Button -->
			<div class="lg:hidden flex items-center">
				<button id="mobile-menu-button" type="button" class="text-white/70 hover:text-white p-2 transition-transform active:scale-95" aria-label="Toggle menu">
					<svg id="menu-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16" />
					</svg>
					<svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Mobile Navigation Drawer -->
	<div id="mobile-menu" class="hidden lg:hidden bg-olive border-t border-white/10 px-4 pt-2 pb-6 space-y-1 shadow-2xl transition-all duration-300">
		{navigation?.map(item => (
			<div class="border-b border-white/5 last:border-0">
				<div class="flex items-center justify-between">
					<a href={formatUrl(item.href)} class="block px-3 py-4 eyebrow text-white hover:text-white/80 transition-colors">
						{item.name}
					</a>
					{item.subItems && (
						<button class="mobile-submenu-toggle p-3 text-white/50 hover:text-white transition-colors">
							<svg class="w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</button>
					)}
				</div>
				{item.subItems && (
					<div class="hidden pl-4 pr-2 pb-2 space-y-1 bg-black/10 rounded-lg mb-2 overflow-hidden transition-all duration-300">
						{item.subItems.map(subItem => (
							<a href={formatUrl(subItem.href)} class="block px-4 py-3 eyebrow text-white/70 hover:text-white border-l border-white/10 ml-2">
								{subItem.name}
							</a>
						))}
					</div>
				)}
			</div>
		))}
		<div class="pt-6">
			<a href={formatUrl(header_cta_href)} class="block text-center px-6 py-4 bg-terracotta text-white eyebrow hover:bg-terracotta-dark transition-all shadow-lg active:scale-[0.98]">
				{header_cta_text}
			</a>
		</div>
	</div>
</header>

<script>
	function initMenu() {
		const button = document.getElementById('mobile-menu-button');
		const menu = document.getElementById('mobile-menu');
		const menuIcon = document.getElementById('menu-icon');
		const closeIcon = document.getElementById('close-icon');
		const header = document.querySelector('header');

		// Scroll listener for header shadow
		window.addEventListener('scroll', () => {
			if (header) {
				if (window.scrollY > 10) {
					header.classList.add('shadow-xl', 'border-white/10');
					header.classList.remove('border-white/5');
				} else {
					header.classList.remove('shadow-xl', 'border-white/10');
					header.classList.add('border-white/5');
				}
			}
		}, { passive: true });

		if (button && menu && menuIcon && closeIcon) {
			button.onclick = () => {
				const isHidden = menu.classList.contains('hidden');
				if (isHidden) {
					menu.classList.remove('hidden');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					document.body.style.overflow = 'hidden'; // Prevent scroll when menu is open
				} else {
					menu.classList.add('hidden');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					document.body.style.overflow = '';
				}
			};
		}

		// Submenu toggles for mobile
		document.querySelectorAll('.mobile-submenu-toggle').forEach(toggle => {
			toggle.onclick = (e) => {
				e.preventDefault();
				const submenu = (toggle as HTMLElement).parentElement?.nextElementSibling;
				const icon = toggle.querySelector('svg');
				if (submenu && icon) {
					const isHidden = submenu.classList.toggle('hidden');
					icon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
				}
			};
		});
	}

	// Initialize on first load
	initMenu();

	// If using view transitions, re-initialize on page changes
	document.addEventListener('astro:after-swap', initMenu);
</script>
