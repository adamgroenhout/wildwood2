---
import { marked } from 'marked';

interface AccordionItem {
  title: string;
  content?: string;
  items?: string[];
}

interface Props {
  items: AccordionItem[];
  theme?: 'standard' | 'large';
  class?: string;
}

const { 
  items, 
  theme = 'standard',
  class: className = ''
} = Astro.props;

const titleClasses = theme === 'large' 
  ? 'py-6 text-3xl md:text-4xl font-serif italic hover:text-terracotta transition-colors'
  : 'py-4 text-xl md:text-2xl font-serif italic hover:text-terracotta transition-colors';
---

<div class:list={['space-y-2', className]}>
  {items.map((item) => (
    <details class="group border-b border-current/10 last:border-0">
      <summary class:list={['flex justify-between items-center cursor-pointer list-none py-2', titleClasses]}>
        <span>{item.title}</span>
        <svg class="w-6 h-6 transition-transform duration-500 group-open:rotate-45 opacity-40 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6v12m6-6H6" />
        </svg>
      </summary>
      <div class="pt-2 pb-10 prose body-lg max-w-none opacity-0 translate-y-2 group-open:opacity-90 group-open:translate-y-0 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]">
        {item.content && <div set:html={marked.parse(item.content)} />}
        {item.items && (
          <ul class="list-disc pl-6 space-y-2">
            {item.items.map(listItem => (
              <li>{listItem}</li>
            ))}
          </ul>
        )}
      </div>
    </details>
  ))}
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
