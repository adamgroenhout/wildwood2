---
import { marked } from 'marked';

interface AccordionItem {
  title: string;
  content?: string;
  items?: string[];
}

interface Props {
  items: AccordionItem[];
  theme?: 'standard' | 'large';
  class?: string;
}

const { 
  items, 
  theme = 'standard',
  class: className = ''
} = Astro.props;

const titleClasses = theme === 'large' 
  ? 'py-4 text-3xl font-serif italic hover:text-terracotta transition-colors'
  : 'py-2 text-xl font-serif italic hover:text-terracotta transition-colors';
---

<div class:list={['space-y-4', className]}>
  {items.map((item) => (
    <details class="group border-b border-current/10 last:border-0 pb-4">
      <summary class:list={['flex justify-between items-center cursor-pointer list-none', titleClasses]}>
        <span>{item.title}</span>
        <span class="text-3xl transition-transform group-open:rotate-45 block leading-none">+</span>
      </summary>
      <div class="pt-4 pb-6 prose body-lg max-w-none opacity-90 group-open:animate-fade-in">
        {item.content && <div set:html={marked.parse(item.content)} />}
        {item.items && (
          <ul class="list-disc pl-6 space-y-2">
            {item.items.map(listItem => (
              <li>{listItem}</li>
            ))}
          </ul>
        )}
      </div>
    </details>
  ))}
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
